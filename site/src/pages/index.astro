---
import Base from '../layouts/Base.astro';
import 'cal-heatmap/cal-heatmap.css';
---
<Base title="vibestats">
  <main class="max-w-4xl mx-auto px-4 py-20">

    <!-- Hero -->
    <section class="text-center mb-24">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-orange-50 dark:bg-orange-950/50 border border-orange-200 dark:border-orange-900 text-orange-600 dark:text-orange-400 text-xs font-medium mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-orange-500 animate-pulse"></span>
        Now tracking Claude Code sessions
      </div>
      <h1 class="text-5xl font-bold tracking-tight text-slate-900 dark:text-white mb-5">
        Track your Claude Code sessions
      </h1>
      <p class="text-lg text-slate-500 dark:text-slate-400 max-w-xl mx-auto">
        Automatically capture every session and render a GitHub-style heatmap
        on your profile — zero manual commands.
      </p>
    </section>

    <!-- Install -->
    <section class="mb-24">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-4">Install</h2>
      <div class="flex items-center gap-3 flex-wrap">
        <div class="flex-1 min-w-0 flex items-center gap-3 bg-slate-950 dark:bg-slate-900 border border-slate-800 rounded-lg px-4 py-3">
          <span class="text-slate-500 select-none">$</span>
          <code id="install-cmd" class="text-sm text-slate-100 font-mono truncate">curl -sSf https://vibestats.dev/install.sh | bash</code>
        </div>
        <button
          id="copy-btn"
          type="button"
          aria-live="polite"
          class="shrink-0 px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors cursor-pointer"
        >
          Copy
        </button>
      </div>
      <script>
        const btn = document.getElementById('copy-btn');
        const cmdEl = document.getElementById('install-cmd');
        if (btn instanceof HTMLButtonElement && cmdEl) {
          let resetTimer: number | undefined;
          btn.addEventListener('click', async () => {
            const cmd = cmdEl.textContent ?? '';
            try {
              await navigator.clipboard.writeText(cmd);
              btn.textContent = 'Copied!';
            } catch {
              btn.textContent = 'Failed';
            }
            if (resetTimer !== undefined) window.clearTimeout(resetTimer);
            resetTimer = window.setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
          });
        }
      </script>
    </section>

    <!-- Heatmap -->
    <section class="mb-24">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-4">See it in action</h2>
      <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 p-6 overflow-x-auto">
        <div id="demo-heatmap"></div>
      </div>
    </section>

    <script>
      import CalHeatmap from 'cal-heatmap';
      import Tooltip from 'cal-heatmap/plugins/Tooltip';

      // Generate realistic demo data for the past 12 months
      const data: { date: string; value: number }[] = [];
      const now = new Date();
      for (let d = 364; d >= 0; d--) {
        const date = new Date(now);
        date.setDate(date.getDate() - d);
        const dow = date.getDay();
        const isWeekend = dow === 0 || dow === 6;
        const rand = Math.random();
        let value = 0;
        if (!isWeekend && rand > 0.35) value = Math.floor(rand * 12) + 1;
        else if (isWeekend && rand > 0.7) value = Math.floor(rand * 5) + 1;
        if (value > 0) {
          data.push({ date: date.toISOString().slice(0, 10), value });
        }
      }

      // Start from 12 months ago, aligned to the first of that month
      const start = new Date(now);
      start.setMonth(start.getMonth() - 11);
      start.setDate(1);

      const cal = new CalHeatmap();
      cal.paint(
        {
          itemSelector: '#demo-heatmap',
          data: { source: data, x: 'date', y: 'value', defaultValue: 0 },
          date: { start },
          range: 12,
          domain: {
            type: 'month',
            label: { text: 'MMM', textAlign: 'start', position: 'top' },
          },
          subDomain: {
            type: 'ghDay',
            width: 11,
            height: 11,
            radius: 2,
          },
          scale: {
            color: {
              type: 'threshold',
              range: ['#1e293b', '#fed7aa', '#fb923c', '#f97316', '#c2410c'],
              domain: [1, 3, 7, 12],
            },
          },
        },
        [
          [
            Tooltip,
            {
              text: (_timestamp: number, value: number | null, dayjsDate: { format: (f: string) => string }) => {
                const label = dayjsDate.format('MMM D, YYYY');
                return value ? `${value} session${value === 1 ? '' : 's'} · ${label}` : `No sessions · ${label}`;
              },
            },
          ],
        ]
      );
    </script>

    <!-- Why -->
    <section class="mb-24">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-6">Why vibestats?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 p-5">
          <div class="text-orange-500 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <h3 class="font-semibold text-slate-900 dark:text-white mb-1">Zero effort</h3>
          <p class="text-sm text-slate-500 dark:text-slate-400">Hooks fire silently on every session. No manual commands needed.</p>
        </div>
        <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 p-5">
          <div class="text-orange-500 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="10" x="2" y="3" rx="2"/><path d="M10 17v4M7 21h10M22 7v4"/></svg>
          </div>
          <h3 class="font-semibold text-slate-900 dark:text-white mb-1">Cross-machine</h3>
          <p class="text-sm text-slate-500 dark:text-slate-400">All your machines, one repository. Data is always in sync.</p>
        </div>
        <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 p-5">
          <div class="text-orange-500 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          </div>
          <h3 class="font-semibold text-slate-900 dark:text-white mb-1">GitHub profile</h3>
          <p class="text-sm text-slate-500 dark:text-slate-400">Heatmap embeds in your README and links to your dashboard.</p>
        </div>
      </div>
    </section>

  </main>
</Base>
