---
import Base from '../layouts/Base.astro';
import 'cal-heatmap/cal-heatmap.css';
---
<Base title="vibestats">
  <main class="landing">

    <!-- Hero -->
    <section class="hero">
      <div class="badge">
        <span class="badge-dot"></span>
        Now tracking Claude Code and Codex sessions
      </div>
      <h1>Show the world how you code with AI</h1>
      <p class="hero-sub">
        Every session. Every token. Every machine — tracked automatically.<br/>
        One install gets you a GitHub-style heatmap and a full analytics dashboard.
      </p>
    </section>

    <!-- Install -->
    <section class="section">
      <h2 class="section-label">Install on every machine you use AI coding tools</h2>
      <div class="install-row">
        <div class="install-box">
          <span class="install-dollar">$</span>
          <code id="install-cmd">curl -sSf https://vibestats.dev/install.sh | bash</code>
        </div>
        <button id="copy-btn" type="button" aria-live="polite" class="copy-btn">Copy</button>
      </div>
      <script>
        const btn = document.getElementById('copy-btn');
        const cmdEl = document.getElementById('install-cmd');
        if (btn instanceof HTMLButtonElement && cmdEl) {
          let resetTimer: number | undefined;
          btn.addEventListener('click', async () => {
            const cmd = cmdEl.textContent ?? '';
            try {
              await navigator.clipboard.writeText(cmd);
              btn.textContent = 'Copied!';
            } catch {
              btn.textContent = 'Failed';
            }
            if (resetTimer !== undefined) window.clearTimeout(resetTimer);
            resetTimer = window.setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
          });
        }
      </script>
    </section>

    <!-- Demo Heatmap -->
    <section class="section">
      <h2 class="section-label">See it in action <span class="info-icon" role="img" aria-label="Interactive demo with randomized data. Your real dashboard uses live data from your AI coding sessions.">i<span class="info-tooltip">Interactive demo with randomized data. Your real dashboard uses live data from your AI coding sessions.</span></span></h2>
      <div id="demo-tabs" class="demo-tabs">
        <button class="demo-tab active" data-metric="sessions">Sessions</button>
        <button class="demo-tab" data-metric="tokens">Tokens</button>
        <button class="demo-tab" data-metric="active_minutes">Active Time</button>
        <button class="demo-tab" data-metric="tool_uses">Tool Uses</button>
      </div>
      <div class="demo-card">
        <div id="demo-heatmap"></div>
      </div>
      <p class="demo-caption">Try the tabs — your dashboard has the same view.</p>
    </section>

    <script>
      import CalHeatmap from 'cal-heatmap';
      import Tooltip from 'cal-heatmap/plugins/Tooltip';

      // ── Realistic random demo data — one series per metric ──
      type Metric = 'sessions' | 'tokens' | 'active_minutes' | 'tool_uses';
      const SCALES: Record<Metric, { weekday: number; weekend: number; floor: number }> = {
        sessions:       { weekday: 12,        weekend: 5,      floor: 1     },
        tokens:         { weekday: 450_000,   weekend: 80_000, floor: 5_000 },
        active_minutes: { weekday: 240,       weekend: 60,     floor: 5     },
        tool_uses:      { weekday: 80,        weekend: 15,     floor: 2     },
      };
      // Deterministic LCG so values are stable across paints.
      function lcg(seed: number): () => number {
        let s = seed;
        return () => { s = (s * 9301 + 49297) % 233280; return s / 233280; };
      }
      const dataByMetric: Record<Metric, { date: string; value: number }[]> = {
        sessions: [], tokens: [], active_minutes: [], tool_uses: [],
      };
      const now = new Date();
      const baseRand = lcg(20260504); // any fixed seed — keeps the demo identical across reloads
      for (let d = 364; d >= 0; d--) {
        const date = new Date(now);
        date.setDate(date.getDate() - d);
        const dow = date.getDay();
        const isWeekend = dow === 0 || dow === 6;
        const r = baseRand();
        const active = !isWeekend ? r > 0.35 : r > 0.7;
        if (!active) continue;
        const dateKey = date.toISOString().slice(0, 10);
        for (const metric of Object.keys(SCALES) as Metric[]) {
          const scale = SCALES[metric];
          const span = isWeekend ? scale.weekend : scale.weekday;
          const value = Math.floor(r * span) + scale.floor;
          dataByMetric[metric].push({ date: dateKey, value });
        }
      }

      // Color thresholds per metric — mirror site/src/pages/u.astro colorScale().
      const SCALE_BY_METRIC: Record<Metric, { range: string[]; domain: number[] }> = {
        sessions:       { range: ['#ebedf0', '#fed7aa', '#fb923c', '#f97316', '#c2410c'], domain: [1, 3, 7, 12] },
        tokens:         { range: ['#ebedf0', '#dbeafe', '#93c5fd', '#3b82f6', '#1d4ed8'], domain: [1, 50_000, 200_000, 500_000] },
        active_minutes: { range: ['#ebedf0', '#d1fae5', '#6ee7b7', '#10b981', '#047857'], domain: [1, 30, 120, 300] },
        tool_uses:      { range: ['#ebedf0', '#ede9fe', '#c4b5fd', '#8b5cf6', '#6d28d9'], domain: [1, 20, 100, 300] },
      };
      const TOOLTIP_LABEL: Record<Metric, (v: number) => string> = {
        sessions:       (v) => `${v} session${v === 1 ? '' : 's'}`,
        tokens:         (v) => `${v.toLocaleString()} tokens`,
        active_minutes: (v) => `${v} min`,
        tool_uses:      (v) => `${v} tool use${v === 1 ? '' : 's'}`,
      };
      let currentMetric: Metric = 'sessions';

      const isDark = () => document.documentElement.classList.contains('dark');
      const emptyColor = () => isDark() ? '#2a3346' : '#ebedf0';

      const demoCardEl = document.querySelector<HTMLElement>('.demo-card');
      function scrollDemoToEnd(): void {
        if (!demoCardEl) return;
        requestAnimationFrame(() => {
          requestAnimationFrame(() => { demoCardEl.scrollLeft = demoCardEl.scrollWidth; });
        });
      }

      const start = new Date(now);
      start.setMonth(start.getMonth() - 11);
      start.setDate(1);

      const cal = new CalHeatmap();

      function paintDemo(metric: Metric): Promise<void> {
        const scale = SCALE_BY_METRIC[metric];
        // Override the "0" colour with the theme-aware empty colour.
        const range = [emptyColor(), ...scale.range.slice(1)];
        return cal.paint(
          {
            itemSelector: '#demo-heatmap',
            data: { source: dataByMetric[metric], x: 'date', y: 'value', defaultValue: 0 },
            date: { start },
            range: 12,
            domain: {
              type: 'month',
              label: { text: 'MMM', textAlign: 'start', position: 'top' },
              gutter: 4,
            },
            subDomain: { type: 'ghDay', width: 13, height: 13, radius: 2, gutter: 3 },
            scale: { color: { type: 'threshold', range, domain: scale.domain } },
          },
          [
            [
              Tooltip,
              {
                text: (_t: number, value: number | null, djs: { format: (f: string) => string }) => {
                  const label = djs.format('MMM D, YYYY');
                  return value ? `${TOOLTIP_LABEL[metric](value)} · ${label}` : `No activity · ${label}`;
                },
              },
            ],
          ]
        ).then(scrollDemoToEnd);
      }

      void paintDemo(currentMetric);

      // Tab switching — destroy + repaint with the new metric's series + scale.
      const demoTabsEl = document.getElementById('demo-tabs');
      demoTabsEl?.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.demo-tab') as HTMLButtonElement | null;
        if (!btn) return;
        const metric = btn.dataset.metric as Metric | undefined;
        if (!metric || metric === currentMetric) return;
        currentMetric = metric;
        for (const t of demoTabsEl.querySelectorAll('.demo-tab')) {
          t.classList.toggle('active', t === btn);
        }
        cal.destroy();
        void paintDemo(metric);
      });

      let demoResizeTimer = 0;
      window.addEventListener('resize', () => {
        window.clearTimeout(demoResizeTimer);
        demoResizeTimer = window.setTimeout(scrollDemoToEnd, 100);
      });

      // Re-render heatmap on theme toggle so empty cell colors match.
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        requestAnimationFrame(() => {
          cal.destroy();
          void paintDemo(currentMetric);
        });
      });
    </script>

    <!-- Dashboard Preview -->
    <section class="section">
      <h2 class="section-label">Your analytics dashboard</h2>
      <p class="section-desc">Every vibestats user gets a full analytics dashboard at <strong>vibestats.dev/username</strong>. Here's what you'll see:</p>

      <!-- Mock KPI row with info tooltips -->

      <!-- Mock KPI row -->
      <div class="preview-kpis">
        <div class="preview-kpi">
          <div class="preview-kpi-header"><span class="preview-kpi-label">Total Tokens</span><span class="info-icon" role="img" aria-label="Input + output tokens across all sessions and machines, all time.">i<span class="info-tooltip">Input + output tokens across all sessions and machines, all time.</span></span></div>
          <span class="preview-kpi-value">24.8M</span>
          <span class="preview-kpi-sub up">+12% vs last 30d</span>
        </div>
        <div class="preview-kpi">
          <div class="preview-kpi-header"><span class="preview-kpi-label">Sessions</span><span class="info-icon" role="img" aria-label="Total Claude Code and Codex sessions across all machines, all time.">i<span class="info-tooltip">Total Claude Code and Codex sessions across all machines, all time.</span></span></div>
          <span class="preview-kpi-value">1,247</span>
          <span class="preview-kpi-sub up">+8%</span>
        </div>
        <div class="preview-kpi">
          <div class="preview-kpi-header"><span class="preview-kpi-label">Active Time</span><span class="info-icon" role="img" aria-label="Sum of all session durations across all machines, all time.">i<span class="info-tooltip">Sum of all session durations across all machines, all time.</span></span></div>
          <span class="preview-kpi-value">312h</span>
        </div>
        <div class="preview-kpi">
          <div class="preview-kpi-header"><span class="preview-kpi-label">Current Streak</span><span class="info-icon" role="img" aria-label="Consecutive days with at least one session, ending today.">i<span class="info-tooltip">Consecutive days with at least one session, ending today.</span></span></div>
          <span class="preview-kpi-value">14d</span>
        </div>
        <div class="preview-kpi">
          <div class="preview-kpi-header"><span class="preview-kpi-label">Top Harness</span><span class="info-icon" role="img" aria-label="Share of all-time tokens (input + output) on your most-used harness, across all machines.">i<span class="info-tooltip">Share of all-time tokens (input + output) on your most-used harness, across all machines.</span></span></div>
          <span class="preview-kpi-value">98%</span>
          <span class="preview-kpi-sub">Claude</span>
        </div>
        <div class="preview-kpi">
          <div class="preview-kpi-header"><span class="preview-kpi-label">Tool Uses</span><span class="info-icon" role="img" aria-label="Total tool invocations (file edits, searches, commands, etc.) all time.">i<span class="info-tooltip">Total tool invocations (file edits, searches, commands, etc.) all time.</span></span></div>
          <span class="preview-kpi-value">4.4K</span>
        </div>
      </div>

      <!-- Mock charts grid -->
      <div class="preview-grid">
        <!-- Token chart -->
        <div class="preview-card">
          <h3 class="preview-card-title">Daily Token Consumption <span class="info-icon" role="img" aria-label="Daily input + output tokens over the last 30 days, all machines.">i<span class="info-tooltip">Daily input + output tokens over the last 30 days, all machines.</span></span></h3>
          <div class="preview-bars" id="preview-token-bars"></div>
        </div>
        <!-- Model donut -->
        <div class="preview-card">
          <h3 class="preview-card-title">Model Usage <span class="info-icon" role="img" aria-label="Share of output tokens by model, all time across all machines.">i<span class="info-tooltip">Share of output tokens by model, all time across all machines.</span></span></h3>
          <div class="preview-donut-row">
            <div class="preview-donut"></div>
            <div class="preview-legend">
              <div class="preview-legend-item"><span class="preview-dot" style="background:#f97316"></span>Sonnet 4.5 — 45%</div>
              <div class="preview-legend-item"><span class="preview-dot" style="background:#3b82f6"></span>Opus 4 — 27%</div>
              <div class="preview-legend-item"><span class="preview-dot" style="background:#a855f7"></span>Sonnet 4 — 16%</div>
              <div class="preview-legend-item"><span class="preview-dot" style="background:#06b6d4"></span>Haiku 4.5 — 7%</div>
            </div>
          </div>
        </div>
        <!-- Sparklines -->
        <div class="preview-card">
          <h3 class="preview-card-title">Weekly Trends <span class="info-icon" role="img" aria-label="Last 12 weeks of activity. Each bar = one week's total. Value on right = most recent week.">i<span class="info-tooltip">Last 12 weeks of activity. Each bar = one week's total. Value on right = most recent week.</span></span></h3>
          <div class="preview-spark-rows" id="preview-sparklines"></div>
        </div>
        <!-- Efficiency -->
        <div class="preview-card">
          <h3 class="preview-card-title">Efficiency Metrics <span class="info-icon" role="img" aria-label="Derived ratios over 12 weeks. Tokens/min = throughput. Cache hit % = prompt cache reuse.">i<span class="info-tooltip">Derived ratios over 12 weeks. Tokens/min = throughput. Cache hit % = prompt cache reuse.</span></span></h3>
          <div class="preview-spark-rows" id="preview-efficiency"></div>
        </div>
      </div>
    </section>

    <script>
      // ── Mock token bars ───────────────────────────────────────────
      const tokenBars = document.getElementById('preview-token-bars')!;
      for (let i = 0; i < 30; i++) {
        const bar = document.createElement('div');
        bar.className = 'pbar';
        const isWeekend = i % 7 === 5 || i % 7 === 6;
        const h = isWeekend ? 10 + Math.random() * 25 : 30 + Math.random() * 70;
        bar.style.height = `${h}%`;
        bar.style.background = isWeekend
          ? 'var(--color-text-muted, #9ca3af)'
          : 'linear-gradient(to top, #f97316, #fb923c)';
        tokenBars.appendChild(bar);
      }

      // ── Mock sparklines ───────────────────────────────────────────
      function makePreviewSpark(containerId: string, rows: Array<{label: string; value: string; color: string}>) {
        const container = document.getElementById(containerId)!;
        for (const row of rows) {
          const rowEl = document.createElement('div');
          rowEl.className = 'pspark-row';
          const label = document.createElement('span');
          label.className = 'pspark-label';
          label.textContent = row.label;
          const sparkline = document.createElement('div');
          sparkline.className = 'pspark-line';
          for (let i = 0; i < 12; i++) {
            const bar = document.createElement('div');
            bar.className = 'pspark-bar';
            bar.style.height = `${8 + Math.random() * 92}%`;
            bar.style.background = row.color;
            bar.style.opacity = String(0.3 + (i / 12) * 0.7);
            sparkline.appendChild(bar);
          }
          const val = document.createElement('span');
          val.className = 'pspark-value';
          val.textContent = row.value;
          rowEl.appendChild(label);
          rowEl.appendChild(sparkline);
          rowEl.appendChild(val);
          container.appendChild(rowEl);
        }
      }

      makePreviewSpark('preview-sparklines', [
        { label: 'Sessions', value: '42', color: '#f97316' },
        { label: 'Tokens', value: '1.2M', color: '#3b82f6' },
        { label: 'Active min', value: '487m', color: '#22c55e' },
        { label: 'Messages', value: '1,842', color: '#a855f7' },
      ]);

      makePreviewSpark('preview-efficiency', [
        { label: 'Tokens/min', value: '1.3K', color: '#06b6d4' },
        { label: 'Msgs/session', value: '44', color: '#f97316' },
        { label: 'Cache hit %', value: '72%', color: '#22c55e' },
        { label: 'Tools/session', value: '6.7', color: '#eab308' },
      ]);
    </script>

    <!-- Features -->
    <section class="section">
      <h2 class="section-label">Why vibestats?</h2>
      <div class="features">
        <div class="feature">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <h3>Zero effort</h3>
          <p>Hooks fire silently on every session. No manual commands needed.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="5" x="2" y="3" rx="1"/><path d="M4 8v11a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8"/><path d="M10 12h4"/></svg>
          </div>
          <h3>Long-term retention</h3>
          <p>Claude Code clears local transcripts after 30 days. vibestats archives the stats — not the content — to your private GitHub repo so your history outlives the files.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <h3>Open, free, private</h3>
          <p>MIT-licensed Rust CLI. No paid tier, no third-party server, no account beyond GitHub. Your data lives in your private repo and stays yours.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="12" r="6"/><circle cx="15" cy="12" r="6"/></svg>
          </div>
          <h3>Claude Code + Codex</h3>
          <p>Sessions from both AI coding tools tracked together — one heatmap, one dashboard, your full AI-coding footprint.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="10" x="2" y="3" rx="2"/><path d="M10 17v4M7 21h10M22 7v4"/></svg>
          </div>
          <h3>Cross-machine</h3>
          <p>All your machines, one repository. Data is always in sync.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          </div>
          <h3>GitHub profile</h3>
          <p>Heatmap embeds in your README and links to your dashboard.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
          </div>
          <h3>Rich analytics</h3>
          <p>Token trends, model breakdown, efficiency metrics, streaks, and more.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3>Streak tracking</h3>
          <p>Current and longest streaks. See your consistency at a glance.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
          </div>
          <h3>Dark mode</h3>
          <p>Full dark mode support on the dashboard and GitHub profile SVGs.</p>
        </div>
      </div>
    </section>

  </main>
</Base>

<style>
  .landing {
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem 1rem 6rem;
  }

  /* ── Hero ──────────────────────────────────────────────────────── */
  .hero {
    text-align: center;
    margin-bottom: 4rem;
    padding-top: 3rem;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
    background: #fff7ed;
    border: 1px solid #fed7aa;
    color: #ea580c;
  }
  :global(.dark) .badge {
    background: rgba(249, 115, 22, 0.08);
    border-color: rgba(249, 115, 22, 0.3);
    color: #fb923c;
  }
  .badge-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #f97316;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .hero h1 {
    font-size: 3rem;
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }
  .hero-sub {
    font-size: 1.1rem;
    color: #64748b;
    max-width: 540px;
    margin: 0 auto;
    line-height: 1.6;
  }
  :global(.dark) .hero-sub { color: #94a3b8; }

  /* ── Sections ──────────────────────────────────────────────────── */
  .section {
    margin-bottom: 4rem;
  }
  .section-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #94a3b8;
    margin-bottom: 1rem;
  }
  :global(.dark) .section-label { color: #64748b; }
  .section-desc {
    font-size: 0.9rem;
    color: #64748b;
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }
  :global(.dark) .section-desc { color: #94a3b8; }
  .section-desc strong { color: #f97316; font-weight: 600; }

  /* ── Install ───────────────────────────────────────────────────── */
  .install-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .install-box {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    background: #0f172a;
    border: 1px solid #1e293b;
  }
  :global(.dark) .install-box {
    background: #1e293b;
    border-color: #334155;
  }
  .install-dollar {
    color: #475569;
    user-select: none;
  }
  .install-box code {
    font-size: 0.875rem;
