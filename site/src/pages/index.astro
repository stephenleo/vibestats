---
import Base from '../layouts/Base.astro';
import 'cal-heatmap/cal-heatmap.css';
const INSTALL_CMD = 'curl -sSf https://vibestats.dev/install.sh | bash';
---
<Base title="VibeStats — show the world how you code">
  <main class="landing">

    <!-- ── Hero ──────────────────────────────────────────────────── -->
    <section class="hero">
      <div class="hero-copy">
        <div class="eyebrow">
          <span class="eyebrow-dot"></span>
          Now tracking Claude Code &amp; Codex
        </div>
        <h1>Show the world how you code!</h1>
        <p class="hero-sub">
          Every session, every token, every machine — tracked automatically.
          One install gets you a GitHub-style heatmap and a full analytics
          dashboard at <strong>vibestats.dev/username</strong>.
        </p>

        <!-- Terminal install card -->
        <div class="terminal">
          <div class="terminal-head">
            <span class="dot dot-r"></span><span class="dot dot-y"></span><span class="dot dot-g"></span>
            <span class="terminal-label">install.sh</span>
            <button id="copy-btn" type="button" aria-live="polite" class="copy-btn">Copy</button>
          </div>
          <div class="terminal-body">
            <span class="prompt">$</span> <code id="install-cmd">{INSTALL_CMD}</code>
          </div>
        </div>

        <div class="trust-row">
          <span>✓ Zero config</span>
          <span>✓ MIT-licensed</span>
          <span>✓ Private by default</span>
        </div>
      </div>

      <!-- Browser-framed dashboard preview -->
      <div class="browser">
        <div class="browser-head">
          <span class="dot dot-r"></span><span class="dot dot-y"></span><span class="dot dot-g"></span>
          <span class="browser-url">vibestats.dev/username</span>
        </div>
        <div class="browser-body">
          <div class="mini-kpis">
            <div class="mini-kpi"><span class="mini-kpi-label">Tokens</span><span class="mini-kpi-value">24.8M</span></div>
            <div class="mini-kpi"><span class="mini-kpi-label">Sessions</span><span class="mini-kpi-value">1,247</span></div>
            <div class="mini-kpi"><span class="mini-kpi-label">Streak</span><span class="mini-kpi-value accent">14d</span></div>
          </div>
          <div class="mini-section">
            <div class="mini-section-head"><span>Contributions</span><span class="mini-faint">last 12 months</span></div>
            <div id="hero-heatmap" class="mini-heatmap" aria-hidden="true"></div>
          </div>
        </div>
      </div>
    </section>

    <script>
      // ── Copy button ──────────────────────────────────────────────
      const btn = document.getElementById('copy-btn');
      const cmdEl = document.getElementById('install-cmd');
      if (btn instanceof HTMLButtonElement && cmdEl) {
        let resetTimer: number | undefined;
        btn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(cmdEl.textContent ?? '');
            btn.textContent = 'Copied ✓';
          } catch {
            btn.textContent = 'Failed';
          }
          if (resetTimer !== undefined) window.clearTimeout(resetTimer);
          resetTimer = window.setTimeout(() => { btn.textContent = 'Copy'; }, 1600);
        });
      }

      // ── Hero contributions mini-heatmap (decorative GitHub-green grid) ──
      const GH = ['var(--empty)', '#9be9a8', '#40c463', '#30a14e', '#216e39'];
      function buildMiniHeatmap(el: HTMLElement, weeks: number, seed: number): void {
        let s = seed;
        const rnd = () => { s = (s * 9301 + 49297) % 233280; return s / 233280; };
        el.style.gridTemplateColumns = `repeat(${weeks}, 1fr)`;
        for (let i = 0; i < weeks * 7; i++) {
          const cell = document.createElement('span');
          const r = rnd();
          const step = r < 0.45 ? 0 : r < 0.6 ? 1 : r < 0.8 ? 2 : r < 0.93 ? 3 : 4;
          cell.style.background = GH[step];
          el.appendChild(cell);
        }
      }
      const heroHeat = document.getElementById('hero-heatmap');
      if (heroHeat) buildMiniHeatmap(heroHeat, 24, 20260504);
    </script>

    <!-- ── Interactive demo ──────────────────────────────────────── -->
    <section class="section center">
      <p class="kicker">Live demo</p>
      <h2 class="h2">See it in action</h2>
      <p class="section-sub">Randomized sample data — switch metrics to explore.</p>

      <div class="card demo-card">
        <div id="demo-tabs" class="pill-tabs">
          <button class="pill active" data-metric="sessions">Sessions</button>
          <button class="pill" data-metric="tokens">Tokens</button>
          <button class="pill" data-metric="active_minutes">Active Time</button>
          <button class="pill" data-metric="tool_uses">Tool Uses</button>
          <button class="pill" data-metric="github">GitHub</button>
        </div>
        <div class="demo-stat-row">
          <div>
            <div id="demo-number" class="big-number">0</div>
            <div id="demo-caption" class="big-caption">tracked this year</div>
          </div>
          <div class="legend-scale">
            <span>Less</span>
            <span id="demo-legend" class="legend-swatches"></span>
            <span>More</span>
          </div>
        </div>
        <div id="demo-heatmap" class="demo-heatmap"></div>
      </div>
    </section>

    <script>
      import CalHeatmap from 'cal-heatmap';
      import Tooltip from 'cal-heatmap/plugins/Tooltip';

      type Metric = 'sessions' | 'tokens' | 'active_minutes' | 'tool_uses' | 'github';
      const SCALES: Record<Metric, { weekday: number; weekend: number; floor: number }> = {
        sessions:       { weekday: 12,        weekend: 5,      floor: 1     },
        tokens:         { weekday: 450_000,   weekend: 80_000, floor: 5_000 },
        active_minutes: { weekday: 240,       weekend: 60,     floor: 5     },
        tool_uses:      { weekday: 80,        weekend: 15,     floor: 2     },
        github:         { weekday: 14,        weekend: 4,      floor: 1     },
      };
      function lcg(seed: number): () => number {
        let s = seed;
        return () => { s = (s * 9301 + 49297) % 233280; return s / 233280; };
      }
      const dataByMetric: Record<Metric, { date: string; value: number }[]> = {
        sessions: [], tokens: [], active_minutes: [], tool_uses: [], github: [],
      };
      const totals: Record<Metric, number> = {
        sessions: 0, tokens: 0, active_minutes: 0, tool_uses: 0, github: 0,
      };
      const now = new Date();
      const baseRand = lcg(20260504);
      for (let d = 364; d >= 0; d--) {
        const date = new Date(now);
        date.setDate(date.getDate() - d);
        const dow = date.getDay();
        const isWeekend = dow === 0 || dow === 6;
        const r = baseRand();
        const active = !isWeekend ? r > 0.35 : r > 0.7;
        if (!active) continue;
        const dateKey = date.toISOString().slice(0, 10);
        for (const metric of Object.keys(SCALES) as Metric[]) {
          const scale = SCALES[metric];
          const span = isWeekend ? scale.weekend : scale.weekday;
          const value = Math.floor(r * span) + scale.floor;
          dataByMetric[metric].push({ date: dateKey, value });
          totals[metric] += value;
        }
      }

      // Color thresholds per metric (mirror u.astro). range = [empty, s2, s3, s4, s5].
      const SCALE_BY_METRIC: Record<Metric, { range: string[]; domain: number[] }> = {
        sessions:       { range: ['#ebedf0', '#fed7aa', '#fb923c', '#f97316', '#c2410c'], domain: [1, 3, 7, 12] },
        tokens:         { range: ['#ebedf0', '#dbeafe', '#93c5fd', '#3b82f6', '#1d4ed8'], domain: [1, 50_000, 200_000, 500_000] },
        active_minutes: { range: ['#ebedf0', '#d1fae5', '#6ee7b7', '#10b981', '#047857'], domain: [1, 30, 120, 300] },
        tool_uses:      { range: ['#ebedf0', '#ede9fe', '#c4b5fd', '#8b5cf6', '#6d28d9'], domain: [1, 20, 100, 300] },
        github:         { range: ['#ebedf0', '#9be9a8', '#40c463', '#30a14e', '#216e39'], domain: [1, 4, 8, 12] },
      };
      const TOOLTIP_LABEL: Record<Metric, (v: number) => string> = {
        sessions:       (v) => `${v} session${v === 1 ? '' : 's'}`,
        tokens:         (v) => `${v.toLocaleString()} tokens`,
        active_minutes: (v) => `${v} min`,
        tool_uses:      (v) => `${v} tool use${v === 1 ? '' : 's'}`,
        github:         (v) => `${v} contribution${v === 1 ? '' : 's'}`,
      };
      const CAPTION: Record<Metric, string> = {
        sessions: 'sessions tracked this year',
        tokens: 'tokens used this year',
        active_minutes: 'minutes active this year',
        tool_uses: 'tool uses this year',
        github: 'contributions this year',
      };
      function fmtNum(metric: Metric, n: number): string {
        if (metric === 'tokens') {
          if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M`;
          if (n >= 1_000) return `${(n / 1_000).toFixed(1)}K`;
        }
        return n.toLocaleString();
      }

      let currentMetric: Metric = 'sessions';
      const isDark = () => document.documentElement.classList.contains('dark');
      const emptyColor = () => isDark() ? '#2a3346' : '#ebedf0';

      const numberEl = document.getElementById('demo-number')!;
      const captionEl = document.getElementById('demo-caption')!;
      const legendEl = document.getElementById('demo-legend')!;
      const demoTabsEl = document.getElementById('demo-tabs')!;

      function updateChrome(metric: Metric): void {
        const range = SCALE_BY_METRIC[metric].range;
        const step4 = range[3];
        numberEl.textContent = fmtNum(metric, totals[metric]);
        numberEl.style.color = step4;
        captionEl.textContent = CAPTION[metric];
        // Legend swatches: empty + 4 active steps (theme-aware empty).
        legendEl.replaceChildren();
        for (const c of [emptyColor(), ...range.slice(1)]) {
          const sw = document.createElement('span');
          sw.className = 'swatch';
          sw.style.background = c;
          legendEl.appendChild(sw);
        }
        // Active pill takes the metric's step-4 color.
        for (const t of demoTabsEl.querySelectorAll<HTMLElement>('.pill')) {
          const active = t.dataset.metric === metric;
          t.classList.toggle('active', active);
          t.style.color = active ? step4 : '';
          t.style.background = active ? `color-mix(in srgb, ${step4} 12%, transparent)` : '';
        }
      }

      const cal = new CalHeatmap();
      const start = new Date(now);
      start.setMonth(start.getMonth() - 11);
      start.setDate(1);

      // Size the cells so the 52-week grid fills the card width (no dead space).
      function demoCellSize(): number {
        const host = document.getElementById('demo-heatmap');
        const w = host?.clientWidth ?? 800;
        return Math.max(10, Math.min(15, Math.round(w / 53) - 3));
      }

      async function paintDemo(metric: Metric): Promise<void> {
        const scale = SCALE_BY_METRIC[metric];
        const range = [emptyColor(), ...scale.range.slice(1)];
        const cell = demoCellSize();
        await cal.paint(
          {
            itemSelector: '#demo-heatmap',
            data: { source: dataByMetric[metric], x: 'date', y: 'value', defaultValue: 0 },
            date: { start },
            range: 12,
            domain: { type: 'month', label: { text: 'MMM', textAlign: 'start', position: 'bottom' }, gutter: 4 },
            subDomain: { type: 'ghDay', width: cell, height: cell, radius: 2, gutter: 3 },
            scale: { color: { type: 'threshold', range, domain: scale.domain } },
          },
          [[Tooltip, {
            text: (_t: number, value: number | null, djs: { format: (f: string) => string }) => {
              const label = djs.format('MMM D, YYYY');
              return value ? `${TOOLTIP_LABEL[metric](value)} · ${label}` : `No activity · ${label}`;
            },
          }]]
        );
        updateChrome(metric);
      }

      void paintDemo(currentMetric);

      demoTabsEl.addEventListener('click', (e) => {
        const b = (e.target as HTMLElement).closest('.pill') as HTMLButtonElement | null;
        if (!b) return;
        const metric = b.dataset.metric as Metric | undefined;
        if (!metric || metric === currentMetric) return;
        currentMetric = metric;
        cal.destroy();
        void paintDemo(metric);
      });

      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        requestAnimationFrame(() => { cal.destroy(); void paintDemo(currentMetric); });
      });

      // Re-fit the grid to the new width on resize.
      let demoResizeTimer = 0;
      window.addEventListener('resize', () => {
        window.clearTimeout(demoResizeTimer);
        demoResizeTimer = window.setTimeout(() => { cal.destroy(); void paintDemo(currentMetric); }, 150);
      });
    </script>

    <!-- ── Dashboard preview ─────────────────────────────────────── -->
    <section class="section">
      <h2 class="h2">Your analytics dashboard</h2>
      <p class="section-sub">Six headline metrics, a weekly token breakdown, and efficiency metrics.</p>

      <div class="kpis">
        <div class="kpi"><span class="kpi-label">Total Tokens</span><span class="kpi-value">24.8M</span><span class="kpi-delta up">▲ 12%</span></div>
        <div class="kpi"><span class="kpi-label">Sessions</span><span class="kpi-value">1,247</span><span class="kpi-delta up">▲ 8%</span></div>
        <div class="kpi"><span class="kpi-label">Active Time</span><span class="kpi-value">312h</span><span class="kpi-delta up">▲ 15%</span></div>
        <div class="kpi"><span class="kpi-label">Streak</span><span class="kpi-value accent">14d</span><span class="kpi-sub">current</span></div>
        <div class="kpi"><span class="kpi-label">Top Harness</span><span class="kpi-value">98%</span><span class="kpi-sub">Claude</span></div>
        <div class="kpi"><span class="kpi-label">Tool Uses</span><span class="kpi-value">4.4K</span><span class="kpi-sub">all time</span></div>
      </div>

      <div class="preview-row">
        <!-- Weekly token consumption (40%) -->
        <div class="card">
          <div class="card-head">
            <h3 class="card-title">Weekly Token Consumption</h3>
            <span class="card-meta">last 12 weeks</span>
          </div>
          <div id="preview-token-bars" class="token-bars"></div>
          <div class="bars-axis"><span>12 weeks ago</span><span>This week</span></div>
          <div class="chart-legend">
            <span class="legend-item"><span class="legend-swatch" style="background:#ea580c"></span>Output</span>
            <span class="legend-item"><span class="legend-swatch" style="background:#fb923c"></span>Input</span>
            <span class="legend-item"><span class="legend-swatch" style="background:#fed7aa"></span>Cache create</span>
          </div>
        </div>
        <!-- Efficiency (40%) -->
        <div class="card">
          <div class="card-head">
            <h3 class="card-title">Efficiency</h3>
            <span class="card-meta">12-week avg</span>
          </div>
          <div id="preview-efficiency" class="eff-rows"></div>
        </div>
        <!-- Model usage (20%) -->
        <div class="card">
          <h3 class="card-title">Model Usage</h3>
          <div class="donut-mini"></div>
          <div class="donut-legend">
            <div class="legend-item"><span class="legend-dot" style="background:var(--accent)"></span>Sonnet 4.5 · 46%</div>
            <div class="legend-item"><span class="legend-dot" style="background:color-mix(in srgb, var(--accent) 70%, #fff)"></span>Opus 4 · 24%</div>
            <div class="legend-item"><span class="legend-dot" style="background:color-mix(in srgb, var(--accent) 46%, #fff)"></span>Sonnet 4 · 16%</div>
          </div>
        </div>
      </div>

      <!-- GitHub contributions -->
      <div class="card gh-card">
        <h3 class="card-title">GitHub Contributions</h3>
        <p class="card-desc">The heatmap that renders on your GitHub profile — includes aggregated private contributions too.</p>
        <div id="preview-gh-heatmap" class="gh-heatmap" aria-hidden="true"></div>
        <div id="preview-gh-months" class="gh-months"></div>
      </div>
    </section>

    <script>
      // ── Weekly token bars (stacked output / input / cache, with grey cap) ──
      const tokenBars = document.getElementById('preview-token-bars');
      if (tokenBars) {
        const rnd = (() => { let s = 7777; return () => { s = (s * 9301 + 49297) % 233280; return s / 233280; }; })();
        for (let i = 0; i < 12; i++) {
          const col = document.createElement('div');
          col.className = 'tbar';
          const fill = 35 + rnd() * 60;
          const out = 40 + Math.round(rnd() * 20);
          const inp = out + Math.round(20 + rnd() * 15);
          // Distinct steps: output (deep), input (mid), cache create (light).
          col.innerHTML =
            `<span class="tbar-fill" style="height:${fill}%;` +
            `background:linear-gradient(to top, #ea580c ${out}%, #fb923c ${out}% ${inp}%, #fed7aa ${inp}%)"></span>`;
          tokenBars.appendChild(col);
        }
      }

      // ── Efficiency rows (value + sparkline) ──
      const effEl = document.getElementById('preview-efficiency');
      if (effEl) {
        const rnd = (() => { let s = 313; return () => { s = (s * 9301 + 49297) % 233280; return s / 233280; }; })();
        const rows = [
          { label: 'Tokens / min', value: '1,324' },
          { label: 'Cache hit rate', value: '71%' },
          { label: 'Avg session', value: '15.0m' },
        ];
        for (const r of rows) {
          const row = document.createElement('div');
          row.className = 'eff-row';
          let spark = '';
          for (let i = 0; i < 12; i++) {
            spark += `<span style="height:${15 + rnd() * 85}%"></span>`;
          }
          row.innerHTML =
            `<div class="eff-meta"><span class="eff-label">${r.label}</span><span class="eff-value">${r.value}</span></div>` +
            `<div class="eff-spark">${spark}</div>`;
          effEl.appendChild(row);
        }
      }

      // ── GitHub contributions mock (green grid + month axis) ──
      const ghHeat = document.getElementById('preview-gh-heatmap');
      const ghMonths = document.getElementById('preview-gh-months');
      if (ghHeat && ghMonths) {
        const GH = ['var(--empty)', '#9be9a8', '#40c463', '#30a14e', '#216e39'];
        let s = 4242;
        const rnd = () => { s = (s * 9301 + 49297) % 233280; return s / 233280; };
        const weeks = 52;
        ghHeat.style.gridTemplateColumns = `repeat(${weeks}, 1fr)`;
        for (let i = 0; i < weeks * 7; i++) {
          const cell = document.createElement('span');
          const r = rnd();
          const step = r < 0.5 ? 0 : r < 0.65 ? 1 : r < 0.82 ? 2 : r < 0.93 ? 3 : 4;
          cell.style.background = GH[step];
          ghHeat.appendChild(cell);
        }
        const M = ['Jul','Aug','Sep','Oct','Nov','Dec','Jan','Feb','Mar','Apr','May','Jun'];
        for (const m of M) {
          const sp = document.createElement('span');
          sp.textContent = m;
          ghMonths.appendChild(sp);
        }
      }
    </script>

    <!-- ── How it works ──────────────────────────────────────────── -->
    <section class="section">
      <h2 class="h2">How it works</h2>
      <div class="how-grid">
        <div class="card how-card">
          <div class="how-label">01 · CLI</div>
          <h3 class="how-title">Installed locally</h3>
          <p>Hooks into Claude Code and Codex and records each session into your private <code>vibestats-data</code> repo.</p>
        </div>
        <div class="card how-card">
          <div class="how-label">02 · ACTION</div>
          <h3 class="how-title">Aggregates daily</h3>
          <p>A GitHub Action runs daily, combines every machine's slice, and renders an SVG heatmap.</p>
        </div>
        <div class="card how-card">
          <div class="how-label">03 · PROFILE</div>
          <h3 class="how-title">Lives on your profile</h3>
          <p>The heatmap embeds in your README between markers and links to your full dashboard.</p>
        </div>
      </div>
    </section>

    <!-- ── Why VibeStats ─────────────────────────────────────────── -->
    <section class="section">
      <h2 class="h2">Why VibeStats</h2>
      <div class="features">
        <div class="card feature"><h3>⚡ Zero effort</h3><p>Hooks fire silently on every session. No manual commands.</p></div>
        <div class="card feature"><h3>⏳ Long-term retention</h3><p>Claude Code clears transcripts after 30 days. VibeStats archives the stats — not the content — to your private repo.</p></div>
        <div class="card feature"><h3>🔓 Open, free, private</h3><p>MIT-licensed Rust CLI. No paid tier, no third-party server, no account beyond GitHub.</p></div>
        <div class="card feature"><h3>🤝 Claude Code + Codex</h3><p>Both AI coding tools tracked together — one heatmap, one dashboard.</p></div>
        <div class="card feature"><h3>🖥️ Cross-machine</h3><p>All your machines, one repository. Data always in sync.</p></div>
        <div class="card feature"><h3>🔥 Streaks &amp; trends</h3><p>Token trends, model breakdown, efficiency metrics, and streaks.</p></div>
      </div>
    </section>

    <!-- ── Final CTA ─────────────────────────────────────────────── -->
    <section class="section">
      <div class="cta">
        <h2 class="h2">Private by default</h2>
        <p class="cta-sub">
          Only small JSON aggregates ever leave your machine — and they go to
          exactly one place: your own private GitHub repo. Never your prompts or code.
        </p>
        <div class="terminal cta-terminal">
          <div class="terminal-head">
            <span class="dot dot-r"></span><span class="dot dot-y"></span><span class="dot dot-g"></span>
            <span class="terminal-label">install.sh</span>
            <button id="copy-btn-2" type="button" aria-live="polite" class="copy-btn">Copy</button>
          </div>
          <div class="terminal-body">
            <span class="prompt">$</span> <code id="install-cmd-2">{INSTALL_CMD}</code>
          </div>
        </div>
      </div>
    </section>

    <script>
      const btn2 = document.getElementById('copy-btn-2');
      const cmd2 = document.getElementById('install-cmd-2');
      if (btn2 instanceof HTMLButtonElement && cmd2) {
        let t: number | undefined;
        btn2.addEventListener('click', async () => {
          try { await navigator.clipboard.writeText(cmd2.textContent ?? ''); btn2.textContent = 'Copied ✓'; }
          catch { btn2.textContent = 'Failed'; }
          if (t !== undefined) window.clearTimeout(t);
          t = window.setTimeout(() => { btn2.textContent = 'Copy'; }, 1600);
        });
      }
    </script>

    <p class="star-line">
      ⭐ Found VibeStats useful?
      <a href="https://github.com/stephenleo/vibestats" target="_blank" rel="noopener noreferrer">Star it on GitHub</a>
      to help others discover it.
    </p>

  </main>
</Base>

<style>
  .landing { max-width: 60rem; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

  /* ── Shared ──────────────────────────────────────────────────── */
  .section { margin-top: 6rem; }
  .section.center { text-align: center; }
  .kicker {
    font-family: var(--font-mono);
    font-size: 0.72rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--accent); margin-bottom: 0.6rem;
  }
  .h2 {
    font-size: 2.25rem; font-weight: 700; letter-spacing: -0.02em;
    color: var(--text); line-height: 1.1; margin-bottom: 0.75rem;
  }
  .section-sub { color: var(--muted); font-size: 1.05rem; margin-bottom: 2rem; }
  .center .section-sub { margin-left: auto; margin-right: auto; max-width: 36rem; }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 14px 38px rgba(20, 20, 55, 0.06);
  }
  :global(.dark) .card { box-shadow: 0 18px 46px rgba(0, 0, 0, 0.4); }
  .card-head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; }
  .card-title { font-family: var(--font-display); font-size: 1.05rem; font-weight: 600; color: var(--text); }
