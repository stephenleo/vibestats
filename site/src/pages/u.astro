---
import Base from '../layouts/Base.astro';
---
<Base title="vibestats dashboard">
  <!-- Early fetch: start data download in <head>, before the 316KB module loads -->
  <script is:inline slot="head">
    (function() {
      var RE = /^[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,38})$/;
      var seg = window.location.pathname.split('/').filter(Boolean)[0] || '';
      var user = RE.test(seg) ? seg : '';
      if (user) {
        var url = 'https://raw.githubusercontent.com/' + user + '/' + user + '/main/vibestats/data.json?v=' + Date.now();
        window.__vibestatsData = fetch(url, { cache: 'no-store' })
          .then(function(r) { return r.ok ? r.json() : null; })
         .catch(function() { return null; });
      }
    })();
  </script>

  <main class="dashboard">
    <!-- Header -->
    <div class="dash-header">
      <div class="dash-header-left">
        <img id="dash-avatar" class="dash-avatar" src="" alt="" hidden />
        <div>
          <h1 id="dash-title">vibestats dashboard</h1>
          <p id="dash-subtitle" class="dash-meta"></p>
        </div>
      </div>
      <div id="year-toggle" class="year-pills" aria-label="Select year"></div>
    </div>

    <!-- Loading / Error -->
    <div id="loading-state" class="state-msg">
      <div class="spinner" aria-hidden="true"></div>
      Loading dashboard&hellip;
    </div>
    <div id="error-state" class="state-msg error" hidden></div>

    <!-- Dashboard content (hidden until data loads) -->
    <section id="dashboard-content" hidden>

      <!-- KPI Row -->
      <div id="kpi-row" class="kpi-row"></div>

      <!-- Activity Heatmap (full width) -->
      <div class="card full-width">
        <h3 class="card-title">Activity Heatmap <span class="info-icon" role="img" aria-label="GitHub-style heatmap of daily activity. Use the tabs to switch between metrics. Shows the selected year across all machines.">i<span class="info-tooltip">GitHub-style heatmap of daily activity. Use the tabs to switch between metrics. Shows the selected year across all machines.</span></span></h3>
        <div id="heatmap-tabs" class="tabs">
          <button class="tab active" data-metric="sessions">Sessions</button>
          <button class="tab" data-metric="tokens">Tokens</button>
          <button class="tab" data-metric="active_minutes">Active Time</button>
          <button class="tab" data-metric="tool_uses">Tool Uses</button>
        </div>
        <div class="heatmap-wrapper">
          <div class="day-labels" aria-hidden="true">
            <span></span><span>Mon</span><span></span><span>Wed</span><span></span><span>Fri</span><span></span>
          </div>
          <div id="cal-heatmap"></div>
        </div>
      </div>

      <!-- Token Trend + Model Mix -->
      <div class="grid-2">
        <div class="card">
          <h3 class="card-title">Daily Token Consumption <span id="token-chart-range" class="card-range"></span> <span class="info-icon" role="img" aria-label="Daily input + output tokens over the last 30 days. Darker bars = more output tokens relative to input.">i<span class="info-tooltip">Daily input + output tokens over the last 30 days, all machines. Darker bars = more output tokens relative to input.</span></span></h3>
          <div id="token-chart" class="chart-area"></div>
          <div id="token-chart-labels" class="chart-labels"></div>
        </div>
        <div class="card">
          <h3 class="card-title">Model Usage Breakdown <span class="info-icon" role="img" aria-label="Share of output tokens by model, all time across all machines.">i<span class="info-tooltip">Share of output tokens by model, all time across all machines.</span></span></h3>
          <div id="model-chart" class="donut-wrapper"></div>
        </div>
      </div>

      <!-- Sparkline Trends + Streak -->
      <div class="grid-2">
        <div class="card">
          <h3 class="card-title">Weekly Trends <span class="info-icon" role="img" aria-label="Sparklines showing the last 12 weeks. Each bar is one week's total. The value on the right is the most recent week.">i<span class="info-tooltip">Last 12 weeks of activity. Each bar = one week's total. Value on right = most recent week.</span></span></h3>
          <div id="sparklines"></div>
        </div>
        <div class="card">
          <h3 class="card-title" id="streak-title">Current Streak</h3>
          <p id="streak-subtitle" class="streak-sub"></p>
          <div id="streak-grid" class="streak-visual"></div>
        </div>
      </div>

      <!-- Recent Activity + Efficiency -->
      <div class="grid-2">
        <div class="card">
          <h3 class="card-title">Recent Active Days <span class="info-icon" role="img" aria-label="The 5 most recent days with at least one session, across all machines.">i<span class="info-tooltip">The 5 most recent days with at least one session, across all machines.</span></span></h3>
          <div id="recent-days" class="timeline"></div>
        </div>
        <div class="card">
          <h3 class="card-title">Efficiency Metrics <span class="info-icon" role="img" aria-label="Derived ratios over 12 weeks. Tokens/min = throughput, cache hit % = prompt cache reuse, tools/session = tool invocations per session.">i<span class="info-tooltip">Derived ratios over 12 weeks. Tokens/min = throughput. Cache hit % = prompt cache reuse. Tools/session = tool invocations per session.</span></span></h3>
          <div id="efficiency"></div>
        </div>
      </div>

    </section>
  </main>
</Base>

<script>
  import CalHeatmap from 'cal-heatmap';
  import Tooltip from 'cal-heatmap/plugins/Tooltip';
  import 'cal-heatmap/cal-heatmap.css';

  // ── Types ──────────────────────────────────────────────────────────
  interface DayEntry {
    sessions: number;
    active_minutes: number;
    input_tokens?: number;
    output_tokens?: number;
    cache_read_tokens?: number;
    cache_creation_tokens?: number;
    models?: Record<string, number>;
    longest_session_minutes?: number;
    message_count?: number;
    tool_uses?: number;
    harnesses?: Record<string, { input_tokens: number; output_tokens: number }>;
  }

  interface VibestatsData {
    generated_at: string;
    username: string;
    days: Record<string, DayEntry>;
  }

  // ── DOM refs ───────────────────────────────────────────────────────
  const loadingEl = document.getElementById('loading-state')!;
  const errorEl = document.getElementById('error-state')!;
  const contentEl = document.getElementById('dashboard-content')!;
  const titleEl = document.getElementById('dash-title')!;
  const subtitleEl = document.getElementById('dash-subtitle')!;
  const avatarEl = document.getElementById('dash-avatar') as HTMLImageElement;
  avatarEl.onerror = () => { avatarEl.hidden = true; };
  const yearToggleEl = document.getElementById('year-toggle')!;
  const kpiRowEl = document.getElementById('kpi-row')!;
  const tokenChartEl = document.getElementById('token-chart')!;
  const tokenChartLabelsEl = document.getElementById('token-chart-labels')!;
  const tokenChartRangeEl = document.getElementById('token-chart-range')!;
  const modelChartEl = document.getElementById('model-chart')!;
  const sparklinesEl = document.getElementById('sparklines')!;
  const streakTitleEl = document.getElementById('streak-title')!;
  const streakSubEl = document.getElementById('streak-subtitle')!;
  const streakGridEl = document.getElementById('streak-grid')!;
  const recentDaysEl = document.getElementById('recent-days')!;
  const efficiencyEl = document.getElementById('efficiency')!;
  const heatmapTabsEl = document.getElementById('heatmap-tabs')!;

  // ── Username discovery ─────────────────────────────────────────────
  const GH_RE = /^[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,38})$/;
  const rawSegment = window.location.pathname.split('/').filter(Boolean)[0] ?? '';
  const username = GH_RE.test(rawSegment) ? rawSegment : '';

  if (username) {
    document.title = `vibestats — @${username}`;
    titleEl.textContent = `@${username}`;
    subtitleEl.textContent = 'AI Coding Analytics';
    avatarEl.alt = `${username}'s GitHub avatar`;
    avatarEl.src = `https://github.com/${username}.png?size=80`;
    avatarEl.hidden = false;
  }

  // ── State ──────────────────────────────────────────────────────────
  let calInstance: CalHeatmap | null = null;
  let vibestatsData: VibestatsData | null = null;
  let currentYear = '';
  let currentMetric = 'sessions';

  // ── Helpers ────────────────────────────────────────────────────────
  function showError(msg: string): void {
    loadingEl.hidden = true;
    errorEl.textContent = msg;
    errorEl.hidden = false;
  }

  function clearEl(el: HTMLElement): void {
    while (el.firstChild) el.removeChild(el.firstChild);
  }

  function fmtTokens(n: number): string {
    if (n >= 1_000_000_000) return `${(n / 1_000_000_000).toFixed(1)}B`;
    if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M`;
    if (n >= 1_000) return `${(n / 1_000).toFixed(1)}K`;
    return String(n);
  }

  function fmtMinutes(m: number): string {
    if (m >= 60) return `${Math.round(m / 60)}h`;
    return `${m}m`;
  }

  function fmtDelta(current: number, previous: number): { text: string; up: boolean } {
    if (previous === 0) return { text: current > 0 ? 'new' : '—', up: true };
    const pct = Math.round(((current - previous) / previous) * 100);
    const arrow = pct >= 0 ? '\u25B2' : '\u25BC';
    return { text: `${arrow} ${Math.abs(pct)}%`, up: pct >= 0 };
  }

  function dateStr(d: Date): string { return d.toISOString().slice(0, 10); }

  function daysAgo(n: number): Date {
    const d = new Date();
    d.setDate(d.getDate() - n);
    return d;
  }

  function metricValue(entry: DayEntry, metric: string): number {
    switch (metric) {
      case 'sessions': return entry.sessions;
      case 'tokens': return (entry.input_tokens ?? 0) + (entry.output_tokens ?? 0);
      case 'active_minutes': return entry.active_minutes;
      case 'tool_uses': return entry.tool_uses ?? 0;
      default: return entry.sessions;
    }
  }

  function colorScale(metric: string): { range: string[]; domain: number[] } {
    const isDark = document.documentElement.classList.contains('dark');
    const empty = isDark ? '#2a3346' : '#ebedf0';
    switch (metric) {
      case 'sessions':
        return { range: [empty, '#fef3e8', '#fed7aa', '#fb923c', '#f97316'], domain: [1, 10, 50, 100] };
      case 'tokens':
        return { range: [empty, '#dbeafe', '#93c5fd', '#3b82f6', '#1d4ed8'], domain: [1, 50000, 200000, 500000] };
      case 'active_minutes':
        return { range: [empty, '#d1fae5', '#6ee7b7', '#10b981', '#047857'], domain: [1, 30, 120, 300] };
      case 'tool_uses':
        return { range: [empty, '#ede9fe', '#c4b5fd', '#8b5cf6', '#6d28d9'], domain: [1, 20, 100, 300] };
      default:
        return { range: [empty, '#fef3e8', '#fed7aa', '#fb923c', '#f97316'], domain: [1, 10, 50, 100] };
    }
  }

  // ── Data aggregation helpers ───────────────────────────────────────
  function daysInRange(data: VibestatsData, from: Date, to: Date): DayEntry[] {
    const entries: DayEntry[] = [];
    const d = new Date(from);
    while (d <= to) {
      const key = dateStr(d);
      if (data.days[key]) entries.push(data.days[key]);
      d.setDate(d.getDate() + 1);
    }
    return entries;
  }

  function sumField(entries: DayEntry[], fn: (e: DayEntry) => number): number {
    return entries.reduce((s, e) => s + fn(e), 0);
  }

  // ── KPI rendering ─────────────────────────────────────────────────
  function renderKPIs(data: VibestatsData): void {
    const now = new Date();
    const cur30 = daysInRange(data, daysAgo(29), now);
    const prev30 = daysInRange(data, daysAgo(59), daysAgo(30));
    const allDays = Object.values(data.days);

    const totalTokens = sumField(allDays, e => (e.input_tokens ?? 0) + (e.output_tokens ?? 0));
    const totalSessions = sumField(allDays, e => e.sessions);
    const totalMinutes = sumField(allDays, e => e.active_minutes);
    const totalToolUses = sumField(allDays, e => e.tool_uses ?? 0);

    const dSessions = fmtDelta(sumField(cur30, e => e.sessions), sumField(prev30, e => e.sessions));
    const dTokens = fmtDelta(
      sumField(cur30, e => (e.input_tokens ?? 0) + (e.output_tokens ?? 0)),
      sumField(prev30, e => (e.input_tokens ?? 0) + (e.output_tokens ?? 0))
    );
    const dMinutes = fmtDelta(sumField(cur30, e => e.active_minutes), sumField(prev30, e => e.active_minutes));

    // Streaks
    const activeDates = new Set(Object.keys(data.days));
    let currentStreak = 0;
    const check = new Date(dateStr(now));
    while (activeDates.has(dateStr(check))) { currentStreak++; check.setDate(check.getDate() - 1); }

    // Top harness: largest share of all-time tokens (input + output) per harness.
    const harnessTotals: Record<string, number> = {};
    for (const day of allDays) {
      for (const [h, v] of Object.entries(day.harnesses ?? {})) {
        harnessTotals[h] = (harnessTotals[h] ?? 0) + (v.input_tokens ?? 0) + (v.output_tokens ?? 0);
      }
    }
    const harnessTotal = Object.values(harnessTotals).reduce((s, v) => s + v, 0);
    const topHarness = Object.entries(harnessTotals).sort((a, b) => b[1] - a[1])[0];
    const topHarnessShare = topHarness && harnessTotal > 0
      ? Math.round((topHarness[1] / harnessTotal) * 100)
      : 0;
    const topHarnessName = topHarness
      ? topHarness[0].charAt(0).toUpperCase() + topHarness[0].slice(1)
      : '';
    const topHarnessValue = topHarnessShare > 0 ? `${topHarnessName} ${topHarnessShare}%` : '—';

    const kpis: Array<{ label: string; value: string; info: string; delta?: string; up?: boolean }> = [
      { label: 'Total Tokens', value: fmtTokens(totalTokens), info: 'Input + output tokens across all sessions and machines, all time.', delta: dTokens.text, up: dTokens.up },
      { label: 'Sessions', value: totalSessions.toLocaleString(), info: 'Total AI coding sessions across all machines, all time.', delta: dSessions.text, up: dSessions.up },
      { label: 'Active Time', value: fmtMinutes(totalMinutes), info: 'Sum of all session durations across all machines, all time.', delta: dMinutes.text, up: dMinutes.up },
      { label: 'Current Streak', value: currentStreak > 0 ? `${currentStreak}d` : '—', info: 'Consecutive days with at least one session, ending today.' },
      { label: 'Top Harness', value: topHarnessValue, info: 'Share of all-time tokens (input + output) on your most-used harness, across all machines.' },
      { label: 'Tool Uses', value: fmtTokens(totalToolUses), info: 'Total tool invocations (file edits, searches, commands, etc.) all time.' },
    ];

    clearEl(kpiRowEl);
    for (const k of kpis) {
      const card = document.createElement('div');
      card.className = 'kpi';
      const header = document.createElement('div');
      header.className = 'kpi-header';
      const label = document.createElement('span');
      label.className = 'kpi-label';
      label.textContent = k.label;
      const infoBtn = document.createElement('span');
      infoBtn.className = 'info-icon';
      infoBtn.textContent = 'i';
      infoBtn.setAttribute('role', 'img');
      infoBtn.setAttribute('aria-label', k.info);
      const tooltip = document.createElement('span');
      tooltip.className = 'info-tooltip';
      tooltip.textContent = k.info;
      infoBtn.appendChild(tooltip);
      header.appendChild(label);
      header.appendChild(infoBtn);
      const value = document.createElement('span');
      value.className = 'kpi-value';
      value.textContent = k.value;
      card.appendChild(header);
      card.appendChild(value);
      if (k.delta && k.delta !== '—') {
        const delta = document.createElement('span');
        delta.className = 'kpi-delta' + (k.up ? '' : ' down');
        delta.textContent = k.delta + ' vs last 30d';
        card.appendChild(delta);
      }
      kpiRowEl.appendChild(card);
    }
  }

  // ── Heatmap ────────────────────────────────────────────────────────
  // #cal-heatmap is the actual overflow container (it has `overflow-x: auto`
  // in the stylesheet), so the cal-heatmap SVG scrolls inside it — not
  // inside .heatmap-wrapper. Scroll that element to show the most recent
  // months on narrow viewports.
  const calHeatmapEl = document.getElementById('cal-heatmap');

  function scrollHeatmapToEnd(): void {
    if (!calHeatmapEl) return;
    // Double rAF: cal-heatmap's SVG layout completes across the next
    // paint, so we wait two frames to read a stable scrollWidth.
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        calHeatmapEl.scrollLeft = calHeatmapEl.scrollWidth;
      });
    });
  }

  async function renderHeatmap(selectedYear: string, metric: string): Promise<void> {
    if (!vibestatsData) return;

    if (calInstance) { calInstance.destroy(); calInstance = null; }

    const calData = Object.entries(vibestatsData.days)
      .filter(([date]) => date.startsWith(selectedYear))
      .map(([date, v]) => ({ date, value: metricValue(v, metric) }));

    const now = new Date();
    const yearNum = parseInt(selectedYear, 10);
    const isCurrentYear = yearNum === now.getFullYear();
    const startDate = isCurrentYear
      ? new Date(yearNum - 1, now.getMonth(), now.getDate())
      : new Date(`${selectedYear}-01-01`);
    const range = isCurrentYear ? 13 : 12;
    const scale = colorScale(metric);

    const cal = new CalHeatmap();
    await cal.paint(
      {
        itemSelector: '#cal-heatmap',
        data: {
          source: calData,
          x: (datum) => +new Date(datum['date'] as string),
          y: 'value',
          defaultValue: 0,
        },
        date: { start: startDate },
        range,
        domain: {
          type: 'month',
          label: { text: 'MMM', textAlign: 'start', position: 'top' },
          gutter: 4,
        },
        subDomain: {
          type: 'ghDay',
          radius: 2,
          width: 14,
          height: 14,
          gutter: 3,
        },
        scale: { color: { type: 'threshold', range: scale.range, domain: scale.domain } },
      },
      [
        [
          Tooltip,
          {
            text: (_ts: number, value: number | null, djs: { format: (f: string) => string }) => {
              const dateKey = djs.format('YYYY-MM-DD');
              const day = vibestatsData?.days[dateKey];
              if (!day || value === null || value === 0)
                return `No activity on ${djs.format('MMM D, YYYY')}`;
              const totalTok = (day.input_tokens ?? 0) + (day.output_tokens ?? 0);
              const topModel = day.models
                ? Object.entries(day.models).sort((a, b) => b[1] - a[1])[0]?.[0]
                : null;
              const mStr = topModel ? `, ${topModel.replace(/^claude-/, '')}` : '';
              const tStr = totalTok > 0 ? `, ${fmtTokens(totalTok)} tokens` : '';
              return `${djs.format('MMM D, YYYY')}: ${day.sessions} session${day.sessions === 1 ? '' : 's'}, ~${day.active_minutes} min${tStr}${mStr}`;
            },
          },
        ],
      ]
    );
    calInstance = cal;
    scrollHeatmapToEnd();
  }

  // ── Re-scroll heatmap to most-recent on viewport changes ───────────
  let heatmapResizeTimer = 0;
  window.addEventListener('resize', () => {
    window.clearTimeout(heatmapResizeTimer);
    heatmapResizeTimer = window.setTimeout(scrollHeatmapToEnd, 100);
  });

  // ── Heatmap tabs ───────────────────────────────────────────────────
  heatmapTabsEl.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.tab') as HTMLButtonElement | null;
    if (!btn || !vibestatsData) return;
    const metric = btn.dataset.metric!;
    if (metric === currentMetric) return;
    currentMetric = metric;
    for (const t of heatmapTabsEl.querySelectorAll('.tab')) {
      t.classList.toggle('active', t === btn);
    }
    renderHeatmap(currentYear, metric);
  });

  // ── Re-render heatmap on theme change ───────────────────────────────
  const themeBtn = document.getElementById('theme-toggle');
  themeBtn?.addEventListener('click', () => {
    // Small delay to let the .dark class toggle first
    requestAnimationFrame(() => {
      if (vibestatsData) renderHeatmap(currentYear, currentMetric);
    });
  });

  // ── Token trend chart ──────────────────────────────────────────────
  function renderTokenChart(data: VibestatsData): void {
    const days: Array<{ date: string; input: number; output: number }> = [];
    for (let i = 29; i >= 0; i--) {
      const d = dateStr(daysAgo(i));
      const entry = data.days[d];
      days.push({
        date: d,
        input: entry?.input_tokens ?? 0,
        output: entry?.output_tokens ?? 0,
      });
    }

    const maxVal = Math.max(1, ...days.map(d => d.input + d.output));
    clearEl(tokenChartEl);
    clearEl(tokenChartLabelsEl);
    tokenChartRangeEl.textContent = '(last 30 days)';

    for (const day of days) {
      const bar = document.createElement('div');
      bar.className = 'chart-bar';
      const total = day.input + day.output;
      const hPct = (total / maxVal) * 100;
      bar.style.height = `${Math.max(hPct, 2)}%`;
      const outputPct = total > 0 ? Math.round((day.output / total) * 100) : 50;
      if (total === 0) {
        bar.style.background = 'var(--color-border)';
        bar.style.height = '3%';
      } else {
        bar.style.background = `linear-gradient(to top, var(--color-brand) ${outputPct}%, var(--color-brand-light) ${outputPct}%)`;
      }
      bar.title = `${day.date}: ${fmtTokens(day.output)} output, ${fmtTokens(day.input)} input`;
      tokenChartEl.appendChild(bar);
    }

    for (let i = 0; i < 30; i += 7) {
      const lbl = document.createElement('span');
      const d = new Date(days[i].date + 'T00:00:00');
      lbl.textContent = d.toLocaleDateString('en', { month: 'short', day: 'numeric' });
      tokenChartLabelsEl.appendChild(lbl);
    }
  }

  // ── Model donut chart ──────────────────────────────────────────────
  function renderModelChart(data: VibestatsData): void {
    const modelTotals: Record<string, number> = {};
    for (const d of Object.values(data.days)) {
      for (const [model, count] of Object.entries(d.models ?? {})) {
        modelTotals[model] = (modelTotals[model] ?? 0) + count;
      }
    }

    const sorted = Object.entries(modelTotals).sort((a, b) => b[1] - a[1]);
    const total = sorted.reduce((s, [, v]) => s + v, 0);
    clearEl(modelChartEl);
    if (total === 0) {
      const msg = document.createElement('p');
      msg.style.cssText = 'color:var(--color-text-muted);font-size:0.85rem';
      msg.textContent = 'No model data available';
      modelChartEl.appendChild(msg);
      return;
    }

    const colors = [
      'var(--color-brand)',
      'var(--c-blue)',
      'var(--c-purple)',
      'var(--c-cyan)',
      'var(--c-green)',
      'var(--c-yellow)',
      '#ef4444',
      'var(--color-text-muted)',
    ];
    const isCodexModel = (model: string): boolean => /^(gpt-|o\d|codex)/i.test(model);
    const formatModelLabel = (model: string): string =>
      model === 'Other'
        ? model
        : model.replace(/^claude-/, '').replace(/-(\d)/, ' $1');

    const selected = new Map<string, number>();
    for (const [model, count] of sorted.slice(0, 4)) {
      selected.set(model, count);
    }
    for (const [model, count] of sorted.filter(([model]) => isCodexModel(model)).slice(0, 3)) {
      selected.set(model, count);
    }

    const top: Array<[string, number]> = Array.from(selected.entries())
      .sort((a, b) => b[1] - a[1])
      .slice(0, colors.length - 1);
    const visibleModels = new Set(top.map(([model]) => model));
    const otherTotal = sorted
      .filter(([model]) => !visibleModels.has(model))
      .reduce((s, [, v]) => s + v, 0);
    if (otherTotal > 0) top.push(['Other', otherTotal]);

    const gradientParts: string[] = [];
    const slices: Array<{ name: string; pct: number; color: string }> = [];
    let cumPct = 0;
    for (let i = 0; i < top.length; i++) {
      const pct = (top[i][1] / total) * 100;
      const color = colors[i] ?? colors[colors.length - 1];
      gradientParts.push(`${color} ${cumPct}% ${cumPct + pct}%`);
      slices.push({ name: top[i][0], pct: Math.round(pct), color });
      cumPct += pct;
    }

    const donut = document.createElement('div');
    donut.className = 'donut';
    donut.style.background = `conic-gradient(${gradientParts.join(', ')})`;
    const legend = document.createElement('div');
    legend.className = 'donut-legend';
    for (const s of slices) {
      const item = document.createElement('div');
      item.className = 'legend-item';
      const dot = document.createElement('span');
      dot.className = 'legend-dot';
      dot.style.background = s.color;
      const label = document.createElement('span');
      label.textContent = `${formatModelLabel(s.name)} — ${s.pct}%`;
      item.appendChild(dot);
      item.appendChild(label);
      legend.appendChild(item);
    }
    modelChartEl.appendChild(donut);
    modelChartEl.appendChild(legend);
  }

  // ── Sparklines ─────────────────────────────────────────────────────
  function renderSparklines(data: VibestatsData): void {
    const now = new Date();
    const weeks: Array<{ sessions: number; tokens: number; minutes: number; messages: number }> = [];
    for (let w = 11; w >= 0; w--) {
      const weekEnd = new Date(now);
      weekEnd.setDate(weekEnd.getDate() - w * 7);
      const weekStart = new Date(weekEnd);
      weekStart.setDate(weekStart.getDate() - 6);
      const entries = daysInRange(data, weekStart, weekEnd);
      weeks.push({
        sessions: sumField(entries, e => e.sessions),
        tokens: sumField(entries, e => (e.input_tokens ?? 0) + (e.output_tokens ?? 0)),
        minutes: sumField(entries, e => e.active_minutes),
        messages: sumField(entries, e => e.message_count ?? 0),
      });
    }

    const latestWeek = weeks[weeks.length - 1];
    const metrics = [
      { label: 'Sessions', key: 'sessions' as const, value: String(latestWeek.sessions), color: 'var(--color-brand)' },
      { label: 'Tokens', key: 'tokens' as const, value: fmtTokens(latestWeek.tokens), color: 'var(--c-blue)' },
      { label: 'Active min', key: 'minutes' as const, value: `${latestWeek.minutes}m`, color: 'var(--c-green)' },
      { label: 'Messages', key: 'messages' as const, value: latestWeek.messages.toLocaleString(), color: 'var(--c-purple)' },
    ];

    clearEl(sparklinesEl);
    for (const m of metrics) {
      const row = document.createElement('div');
      row.className = 'spark-row';
      const label = document.createElement('span');
      label.className = 'spark-label';
      label.textContent = m.label;
      const sparkline = document.createElement('div');
      sparkline.className = 'sparkline';
      const vals = weeks.map(w => w[m.key]);
      const max = Math.max(1, ...vals);
      for (let i = 0; i < vals.length; i++) {
        const bar = document.createElement('div');
        bar.className = 'spark-bar';
        bar.style.height = `${Math.max((vals[i] / max) * 100, 3)}%`;
        bar.style.background = m.color;
        bar.style.opacity = String(0.3 + (i / vals.length) * 0.7);
        sparkline.appendChild(bar);
      }
      const value = document.createElement('span');
      value.className = 'spark-value';
      value.textContent = m.value;
      row.appendChild(label);
      row.appendChild(sparkline);
      row.appendChild(value);
      sparklinesEl.appendChild(row);
    }
  }

  // ── Streak calendar ────────────────────────────────────────────────
  function renderStreak(data: VibestatsData): void {
    const activeDates = new Set(Object.keys(data.days));
    const today = dateStr(new Date());

    let currentStreak = 0;
    const check = new Date(today);
    while (activeDates.has(dateStr(check))) { currentStreak++; check.setDate(check.getDate() - 1); }

    let longestStreak = 0, streak = 0;
    const sorted = [...activeDates].sort();
    for (let i = 0; i < sorted.length; i++) {
      if (i === 0) { streak = 1; }
      else {
        const prev = new Date(sorted[i - 1]);
        const curr = new Date(sorted[i]);
        streak = (curr.getTime() - prev.getTime()) / 86_400_000 === 1 ? streak + 1 : 1;
      }
      longestStreak = Math.max(longestStreak, streak);
    }

    streakTitleEl.textContent = `Current Streak — ${currentStreak > 0 ? `${currentStreak} days` : 'none'}`;
    if (longestStreak > 0) {
      streakSubEl.textContent = `Your longest streak was ${longestStreak} days.`;
    }

    const dayNames = ['S', 'M', 'T', 'W', 'T', 'F', 'S'];
    clearEl(streakGridEl);
    for (let i = 27; i >= 0; i--) {
      const d = daysAgo(i);
      const key = dateStr(d);
      const isActive = activeDates.has(key);
      const isToday = key === today;
      const el = document.createElement('div');
      el.className = `streak-day ${isActive ? 'active' : 'inactive'}${isToday ? ' today' : ''}`;
      el.textContent = dayNames[d.getDay()];
      el.title = `${key}: ${isActive ? 'active' : 'no activity'}`;
      streakGridEl.appendChild(el);
    }
  }

  // ── Recent active days ─────────────────────────────────────────────
  function renderRecentDays(data: VibestatsData): void {
    const sorted = Object.entries(data.days)
      .sort(([a], [b]) => b.localeCompare(a))
      .slice(0, 5);

    clearEl(recentDaysEl);
    for (const [date, entry] of sorted) {
      const item = document.createElement('div');
      item.className = 'timeline-item';
      const dot = document.createElement('span');
      dot.className = 'timeline-dot';
      const dateEl = document.createElement('span');
      dateEl.className = 'timeline-time';
      const d = new Date(date + 'T00:00:00');
      dateEl.textContent = d.toLocaleDateString('en', { month: 'short', day: 'numeric' });
      const detail = document.createElement('span');
      detail.className = 'timeline-detail';
      detail.textContent = `${entry.sessions} session${entry.sessions === 1 ? '' : 's'}, ~${entry.active_minutes} min`;
      const tokens = document.createElement('span');
      tokens.className = 'timeline-tokens';
      const totalTok = (entry.input_tokens ?? 0) + (entry.output_tokens ?? 0);
      tokens.textContent = totalTok > 0 ? `${fmtTokens(totalTok)} tokens` : '';
      item.appendChild(dot);
      item.appendChild(dateEl);
      item.appendChild(detail);
      item.appendChild(tokens);
      recentDaysEl.appendChild(item);
    }
  }

  // ── Efficiency metrics ─────────────────────────────────────────────
  function renderEfficiency(data: VibestatsData): void {
    const allDays = Object.values(data.days);
    const totalTokens = sumField(allDays, e => (e.input_tokens ?? 0) + (e.output_tokens ?? 0));
    const totalMinutes = sumField(allDays, e => e.active_minutes);
    const totalSessions = sumField(allDays, e => e.sessions);
    const totalMessages = sumField(allDays, e => e.message_count ?? 0);
    const totalToolUses = sumField(allDays, e => e.tool_uses ?? 0);
    const totalCacheRead = sumField(allDays, e => e.cache_read_tokens ?? 0);
    const totalCacheCreation = sumField(allDays, e => e.cache_creation_tokens ?? 0);
    const totalInput = sumField(allDays, e => e.input_tokens ?? 0);

    const tokPerMin = totalMinutes > 0 ? Math.round(totalTokens / totalMinutes) : 0;
    const msgsPerSession = totalSessions > 0 ? Math.round(totalMessages / totalSessions) : 0;
    const cacheDenom = totalInput + totalCacheCreation;
    const cacheHitPct = cacheDenom > 0 ? Math.round((totalCacheRead / cacheDenom) * 100) : 0;
    const toolsPerSession = totalSessions > 0 ? (totalToolUses / totalSessions).toFixed(1) : '0';

    const now = new Date();
    const weeklyTokPerMin: number[] = [];
    const weeklyMsgsPerSession: number[] = [];
    const weeklyCacheHit: number[] = [];
    const weeklyToolsPerSession: number[] = [];
    for (let w = 11; w >= 0; w--) {
      const weekEnd = new Date(now);
      weekEnd.setDate(weekEnd.getDate() - w * 7);
      const weekStart = new Date(weekEnd);
      weekStart.setDate(weekStart.getDate() - 6);
      const entries = daysInRange(data, weekStart, weekEnd);
      const wTok = sumField(entries, e => (e.input_tokens ?? 0) + (e.output_tokens ?? 0));
      const wMin = sumField(entries, e => e.active_minutes);
      const wSes = sumField(entries, e => e.sessions);
      const wMsg = sumField(entries, e => e.message_count ?? 0);
      const wTool = sumField(entries, e => e.tool_uses ?? 0);
      const wCacheRead = sumField(entries, e => e.cache_read_tokens ?? 0);
      const wInput = sumField(entries, e => e.input_tokens ?? 0);
      const wCacheCreate = sumField(entries, e => e.cache_creation_tokens ?? 0);
      weeklyTokPerMin.push(wMin > 0 ? wTok / wMin : 0);
      weeklyMsgsPerSession.push(wSes > 0 ? wMsg / wSes : 0);
      const wd = wInput + wCacheCreate;
      weeklyCacheHit.push(wd > 0 ? (wCacheRead / wd) * 100 : 0);
      weeklyToolsPerSession.push(wSes > 0 ? wTool / wSes : 0);
    }

    const effMetrics = [
      { label: 'Tokens/min', value: fmtTokens(tokPerMin), data: weeklyTokPerMin, color: 'var(--c-cyan)' },
      { label: 'Msgs/session', value: String(msgsPerSession), data: weeklyMsgsPerSession, color: 'var(--color-brand)' },
      { label: 'Cache hit %', value: `${cacheHitPct}%`, data: weeklyCacheHit, color: 'var(--c-green)', highlight: true },
      { label: 'Tools/session', value: String(toolsPerSession), data: weeklyToolsPerSession, color: 'var(--c-yellow)' },
    ];

    clearEl(efficiencyEl);
    for (const m of effMetrics) {
      const row = document.createElement('div');
      row.className = 'spark-row';
      const label = document.createElement('span');
      label.className = 'spark-label';
      label.textContent = m.label;
      const sparkline = document.createElement('div');
      sparkline.className = 'sparkline';
      const max = Math.max(1, ...m.data);
      for (let i = 0; i < m.data.length; i++) {
        const bar = document.createElement('div');
        bar.className = 'spark-bar';
        bar.style.height = `${Math.max((m.data[i] / max) * 100, 3)}%`;
        bar.style.background = m.color;
        bar.style.opacity = String(0.3 + (i / m.data.length) * 0.7);
        sparkline.appendChild(bar);
      }
      const value = document.createElement('span');
      value.className = 'spark-value';
      value.textContent = m.value;
      if (m.highlight) value.style.color = 'var(--c-green)';
      row.appendChild(label);
      row.appendChild(sparkline);
      row.appendChild(value);
      efficiencyEl.appendChild(row);
    }
  }

  // ── Year toggle ────────────────────────────────────────────────────
  function renderYearToggle(years: string[], selectedYear: string): void {
    clearEl(yearToggleEl);
    for (const year of years) {
      const btn = document.createElement('button');
      btn.textContent = year;
      btn.className = 'year-pill' + (year === selectedYear ? ' active' : '');
      btn.setAttribute('aria-pressed', String(year === selectedYear));
      btn.addEventListener('click', async () => {
        currentYear = year;
        for (const b of yearToggleEl.querySelectorAll('.year-pill')) {
          b.classList.toggle('active', b === btn);
          b.setAttribute('aria-pressed', String(b === btn));
        }
        await renderHeatmap(year, currentMetric);
      });
      yearToggleEl.appendChild(btn);
    }
  }

  // ── Main init ──────────────────────────────────────────────────────
  async function init(): Promise<void> {
    if (!username) {
      showError(`No vibestats data found for @${rawSegment || 'unknown'}`);
      return;
    }

    let data: VibestatsData;
    try {
      const earlyPromise = (window as Record<string, unknown>).__vibestatsData as
        | Promise<VibestatsData | null> | undefined;
      if (earlyPromise) {
        const result = await earlyPromise;
        if (!result) { showError(`No vibestats data found for @${username}`); return; }
        data = result;
      } else {
        const url = `https://raw.githubusercontent.com/${username}/${username}/main/vibestats/data.json?v=${Date.now()}`;
        const resp = await fetch(url, { cache: 'no-store' });
        if (!resp.ok) { showError(`No vibestats data found for @${username}`); return; }
        data = (await resp.json()) as VibestatsData;
      }
    } catch { showError(`No vibestats data found for @${username}`); return; }

    if (!data || typeof data.days !== 'object' || data.days === null) {
      showError(`No vibestats data found for @${username}`);
      return;
    }

    vibestatsData = data;

    const years = [...new Set(Object.keys(data.days).map(d => d.slice(0, 4)))].sort((a, b) => b.localeCompare(a));
    if (years.length === 0) { showError(`No vibestats data found for @${username}`); return; }

    const nowYear = String(new Date().getFullYear());
    currentYear = years.includes(nowYear) ? nowYear : years[0];

    const dayCount = Object.keys(data.days).length;
    const generated = new Date(data.generated_at);
    const ago = Math.round((Date.now() - generated.getTime()) / 3_600_000);
    subtitleEl.textContent = `AI Coding Analytics \u00B7 ${dayCount} active days \u00B7 updated ${ago < 1 ? 'just now' : `${ago}h ago`}`;

    loadingEl.hidden = true;
    contentEl.hidden = false;

    renderKPIs(data);
    renderYearToggle(years, currentYear);
    await renderHeatmap(currentYear, currentMetric);
    renderTokenChart(data);
    renderModelChart(data);
    renderSparklines(data);
    renderStreak(data);
    renderRecentDays(data);
    renderEfficiency(data);
  }

  init();
</script>

