---
import Base from '../layouts/Base.astro';
---
<Base title="VibeStats dashboard">
  <!-- Early fetch: start data download in <head>, before the module loads -->
  <script is:inline slot="head">
    (function() {
      var RE = /^[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,38})$/;
      var seg = window.location.pathname.split('/').filter(Boolean)[0] || '';
      var user = RE.test(seg) ? seg : '';
      if (user) {
        var url = 'https://raw.githubusercontent.com/' + user + '/' + user + '/main/vibestats/data.json?v=' + Date.now();
        window.__vibestatsData = fetch(url, { cache: 'no-store' })
          .then(function(r) { return r.ok ? r.json() : null; })
         .catch(function() { return null; });
      }
    })();
  </script>

  <main class="dashboard">
    <!-- Profile header -->
    <div class="profile">
      <div class="profile-left">
        <img id="dash-avatar" class="avatar" src="" alt="" hidden />
        <div>
          <div class="profile-name-row">
            <h1 id="dash-title">VibeStats dashboard</h1>
            <span id="machines-pill" class="machines-pill" hidden></span>
          </div>
          <p id="dash-subtitle" class="profile-meta"></p>
        </div>
      </div>
      <div class="profile-actions" id="profile-actions" hidden>
        <button id="share-btn" type="button" class="btn-secondary">Share</button>
        <a id="gh-link" class="btn-primary" target="_blank" rel="noopener noreferrer">View on GitHub</a>
      </div>
    </div>

    <!-- Loading / Error -->
    <div id="loading-state" class="state-msg">
      <div class="spinner" aria-hidden="true"></div>
      Loading dashboard&hellip;
    </div>
    <div id="error-state" class="state-msg error" hidden></div>

    <section id="dashboard-content" hidden>

      <!-- KPI Row -->
      <div id="kpi-row" class="kpi-row"></div>

      <!-- Activity Heatmap -->
      <div class="card">
        <div class="card-head">
          <div id="heatmap-tabs" class="pill-tabs">
            <button class="pill active" data-metric="sessions">Sessions</button>
            <button class="pill" data-metric="tokens">Tokens</button>
            <button class="pill" data-metric="active_minutes">Active Time</button>
            <button class="pill" data-metric="tool_uses">Tool Uses</button>
          </div>
          <select id="year-select" class="range-select" aria-label="Select range"></select>
        </div>
        <div class="stat-row">
          <div>
            <div id="heat-number" class="big-number">0</div>
            <div id="heat-caption" class="big-caption"></div>
          </div>
          <div class="legend-scale">
            <span>Less</span><span id="heat-legend" class="legend-swatches"></span><span>More</span>
          </div>
        </div>
        <div id="cal-heatmap"></div>
      </div>

      <!-- 40 / 40 / 20 row -->
      <div class="three-col">
        <!-- Weekly token consumption -->
        <div class="card">
          <div class="card-head">
            <h3 class="card-title">Weekly Token Consumption</h3>
            <span class="card-meta">last 12 weeks</span>
          </div>
          <div id="token-chart" class="token-bars"></div>
          <div class="bars-axis"><span>12 weeks ago</span><span>This week</span></div>
          <div class="chart-legend">
            <span class="legend-item"><span class="legend-swatch" style="background:#ea580c"></span>Output</span>
            <span class="legend-item"><span class="legend-swatch" style="background:#fb923c"></span>Input</span>
            <span class="legend-item"><span class="legend-swatch" style="background:#fed7aa"></span>Cache create</span>
          </div>
        </div>
        <!-- Efficiency -->
        <div class="card">
          <div class="card-head">
            <h3 class="card-title">Efficiency</h3>
            <span class="card-meta">12-week avg</span>
          </div>
          <div id="efficiency" class="eff-rows"></div>
        </div>
        <!-- Model usage -->
        <div class="card">
          <h3 class="card-title">Model Usage</h3>
          <div id="model-chart" class="donut-wrapper"></div>
        </div>
      </div>

      <!-- GitHub Contributions -->
      <div id="github-card" class="card gh-card" hidden>
        <h3 class="card-title">GitHub Contributions</h3>
        <p class="card-desc">The heatmap that renders on your GitHub profile — includes your aggregated private contributions too, updated daily.</p>
        <div class="gh-panel">
          <div class="gh-panel-head">
            <span id="gh-panel-label" class="gh-panel-label"></span>
            <div class="gh-panel-right">
              <span id="gh-count" class="gh-count"></span>
              <select id="gh-year-select" class="range-select" aria-label="Select GitHub range"></select>
            </div>
          </div>
          <div id="gh-heatmap"></div>
        </div>
      </div>

    </section>

    <p class="star-line">
      ⭐ Found VibeStats useful?
      <a href="https://github.com/stephenleo/vibestats" target="_blank" rel="noopener noreferrer">Star it on GitHub</a>
      to help others discover it.
    </p>
  </main>
</Base>

<script>
  import CalHeatmap from 'cal-heatmap';
  import Tooltip from 'cal-heatmap/plugins/Tooltip';
  import 'cal-heatmap/cal-heatmap.css';

  // ── Types ──────────────────────────────────────────────────────────
  interface DayEntry {
    sessions: number;
    active_minutes: number;
    input_tokens?: number;
    output_tokens?: number;
    cache_read_tokens?: number;
    cache_creation_tokens?: number;
    models?: Record<string, number>;
    longest_session_minutes?: number;
    message_count?: number;
    tool_uses?: number;
    harnesses?: Record<string, { input_tokens: number; output_tokens: number; cache_creation_tokens?: number }>;
  }
  interface GithubDay { total: number; commits: number; prs: number; issues: number; reviews: number; }
  interface VibestatsData {
    generated_at: string;
    username: string;
    days: Record<string, DayEntry>;
    github_contributions?: Record<string, GithubDay>;
    machines?: unknown[];
  }

  // ── DOM refs ───────────────────────────────────────────────────────
  const loadingEl = document.getElementById('loading-state')!;
  const errorEl = document.getElementById('error-state')!;
  const contentEl = document.getElementById('dashboard-content')!;
  const titleEl = document.getElementById('dash-title')!;
  const subtitleEl = document.getElementById('dash-subtitle')!;
  const avatarEl = document.getElementById('dash-avatar') as HTMLImageElement;
  avatarEl.onerror = () => { avatarEl.hidden = true; };
  const machinesPillEl = document.getElementById('machines-pill')!;
  const profileActionsEl = document.getElementById('profile-actions')!;
  const shareBtnEl = document.getElementById('share-btn')!;
  const ghLinkEl = document.getElementById('gh-link') as HTMLAnchorElement;
  const yearSelectEl = document.getElementById('year-select') as HTMLSelectElement;
  const kpiRowEl = document.getElementById('kpi-row')!;
  const heatNumberEl = document.getElementById('heat-number')!;
  const heatCaptionEl = document.getElementById('heat-caption')!;
  const heatLegendEl = document.getElementById('heat-legend')!;
  const tokenChartEl = document.getElementById('token-chart')!;
  const modelChartEl = document.getElementById('model-chart')!;
  const efficiencyEl = document.getElementById('efficiency')!;
  const heatmapTabsEl = document.getElementById('heatmap-tabs')!;
  const githubCardEl = document.getElementById('github-card')!;
  const ghYearSelectEl = document.getElementById('gh-year-select') as HTMLSelectElement;
  const ghCountEl = document.getElementById('gh-count')!;
  const ghPanelLabelEl = document.getElementById('gh-panel-label')!;

  // ── Username discovery ─────────────────────────────────────────────
  const GH_RE = /^[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,38})$/;
  const rawSegment = window.location.pathname.split('/').filter(Boolean)[0] ?? '';
  const username = GH_RE.test(rawSegment) ? rawSegment : '';

  if (username) {
    document.title = `VibeStats — @${username}`;
    titleEl.textContent = username;
    avatarEl.alt = `${username}'s GitHub avatar`;
    avatarEl.src = `https://github.com/${username}.png?size=120`;
    avatarEl.hidden = false;
    ghLinkEl.href = `https://github.com/${username}`;
    profileActionsEl.hidden = false;
    ghPanelLabelEl.textContent = `${username}'s GitHub contributions`;
  }

  // ── State ──────────────────────────────────────────────────────────
  let calInstance: CalHeatmap | null = null;
  let ghInstance: CalHeatmap | null = null;
  let vibestatsData: VibestatsData | null = null;
  let currentRange: 'L12M' | string = 'L12M';
  let ghRange: 'L12M' | string = 'L12M';
  let currentMetric = 'sessions';

  // ── Helpers ────────────────────────────────────────────────────────
  function showError(msg: string): void {
    loadingEl.hidden = true;
    errorEl.textContent = msg;
    errorEl.hidden = false;
  }
  function clearEl(el: HTMLElement): void { while (el.firstChild) el.removeChild(el.firstChild); }
  function fmtTokens(n: number): string {
    if (n >= 1_000_000_000) return `${(n / 1_000_000_000).toFixed(1)}B`;
    if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M`;
    if (n >= 1_000) return `${(n / 1_000).toFixed(1)}K`;
    return String(n);
  }
  function fmtMinutes(m: number): string { return m >= 60 ? `${Math.round(m / 60)}h` : `${m}m`; }
  function fmtDelta(current: number, previous: number): { text: string; up: boolean } {
    if (previous === 0) return { text: current > 0 ? 'new' : '—', up: true };
    const pct = Math.round(((current - previous) / previous) * 100);
    const arrow = pct >= 0 ? '▲' : '▼';
    return { text: `${arrow} ${Math.abs(pct)}%`, up: pct >= 0 };
  }
  function dateStr(d: Date): string { return d.toISOString().slice(0, 10); }
  function daysAgo(n: number): Date { const d = new Date(); d.setDate(d.getDate() - n); return d; }

  function metricValue(entry: DayEntry, metric: string): number {
    switch (metric) {
      case 'sessions': return entry.sessions;
      case 'tokens': return tokensTotal(entry);
      case 'active_minutes': return entry.active_minutes;
      case 'tool_uses': return entry.tool_uses ?? 0;
      default: return entry.sessions;
    }
  }

  // Per-metric colour ramps (4 active steps). GitHub keeps its canonical green.
  const PALETTES: Record<string, string[]> = {
    sessions:       ['#fed7aa', '#fb923c', '#f97316', '#c2410c'],
    tokens:         ['#93c5fd', '#60a5fa', '#3b82f6', '#1d4ed8'],
    active_minutes: ['#6ee7b7', '#34d399', '#10b981', '#047857'],
    tool_uses:      ['#c4b5fd', '#a78bfa', '#8b5cf6', '#6d28d9'],
    github:         ['#9be9a8', '#40c463', '#30a14e', '#216e39'],
  };
  // Step-4 (headline) colour per metric — the saturated mid-dark step.
  const STEP4: Record<string, string> = {
    sessions: '#f97316', tokens: '#3b82f6', active_minutes: '#10b981', tool_uses: '#8b5cf6', github: '#30a14e',
  };
  const METRIC_CAPTION: Record<string, string> = {
    sessions: 'sessions across all machines',
    tokens: 'tokens across all machines',
    active_minutes: 'minutes active across all machines',
    tool_uses: 'tool uses across all machines',
  };
  function metricNumber(metric: string, n: number): string {
    if (metric === 'tokens') return fmtTokens(n);
    if (metric === 'active_minutes') return fmtMinutes(n);
    return n.toLocaleString();
  }

  function quantile(sortedAsc: number[], q: number): number {
    const idx = Math.min(sortedAsc.length - 1, Math.floor(sortedAsc.length * q));
    return sortedAsc[idx];
  }
  function niceCeil(n: number): number {
    if (n <= 10) return Math.ceil(n);
    const mag = Math.pow(10, Math.floor(Math.log10(n)));
    return Math.ceil(n / mag) * mag;
  }
  function emptyColor(): string {
    return document.documentElement.classList.contains('dark') ? '#2a3346' : '#ebedf0';
  }
  function colorScale(metric: string, values: number[]): { range: string[]; domain: number[] } {
    const empty = emptyColor();
    const palette = PALETTES[metric] ?? PALETTES.sessions;
    const nz = values.filter(v => v > 0).sort((a, b) => a - b);
    if (nz.length === 0) return { range: [empty, ...palette], domain: [1, 2, 3, 4] };
    const raw = [1, niceCeil(quantile(nz, 0.4)), niceCeil(quantile(nz, 0.7)), niceCeil(quantile(nz, 0.9))];
    const domain: number[] = [];
    for (const v of raw) {
      const prev = domain[domain.length - 1];
      domain.push(prev !== undefined && v <= prev ? prev + 1 : v);
    }
    return { range: [empty, ...palette], domain };
  }

  // ── Data aggregation helpers ───────────────────────────────────────
  function daysInRange(data: VibestatsData, from: Date, to: Date): DayEntry[] {
    const entries: DayEntry[] = [];
    const d = new Date(from);
    while (d <= to) {
      const key = dateStr(d);
      if (data.days[key]) entries.push(data.days[key]);
      d.setDate(d.getDate() + 1);
    }
    return entries;
  }
  function sumField(entries: DayEntry[], fn: (e: DayEntry) => number): number {
    return entries.reduce((s, e) => s + fn(e), 0);
  }
  function tokensTotal(e: DayEntry): number {
    return (e.input_tokens ?? 0) + (e.output_tokens ?? 0) + (e.cache_creation_tokens ?? 0);
  }

  // ── KPI rendering ─────────────────────────────────────────────────
  function renderKPIs(data: VibestatsData): void {
    const now = new Date();
    const cur30 = daysInRange(data, daysAgo(29), now);
    const prev30 = daysInRange(data, daysAgo(59), daysAgo(30));
    const allDays = Object.values(data.days);

    const totalTokens = sumField(allDays, tokensTotal);
    const totalSessions = sumField(allDays, e => e.sessions);
    const totalMinutes = sumField(allDays, e => e.active_minutes);
    const totalToolUses = sumField(allDays, e => e.tool_uses ?? 0);

    const dSessions = fmtDelta(sumField(cur30, e => e.sessions), sumField(prev30, e => e.sessions));
    const dTokens = fmtDelta(sumField(cur30, tokensTotal), sumField(prev30, tokensTotal));
    const dMinutes = fmtDelta(sumField(cur30, e => e.active_minutes), sumField(prev30, e => e.active_minutes));

    const activeDates = new Set(Object.keys(data.days));
    let currentStreak = 0;
    const check = new Date(dateStr(now));
    while (activeDates.has(dateStr(check))) { currentStreak++; check.setDate(check.getDate() - 1); }
    let longestStreak = 0, streak = 0;
    const sortedDates = [...activeDates].sort();
    for (let i = 0; i < sortedDates.length; i++) {
      if (i === 0) streak = 1;
      else {
        const prev = new Date(sortedDates[i - 1]);
        const curr = new Date(sortedDates[i]);
        streak = (curr.getTime() - prev.getTime()) / 86_400_000 === 1 ? streak + 1 : 1;
      }
      longestStreak = Math.max(longestStreak, streak);
    }

    const harnessTotals: Record<string, number> = {};
    for (const day of allDays) {
      for (const [h, v] of Object.entries(day.harnesses ?? {})) {
        harnessTotals[h] = (harnessTotals[h] ?? 0)
          + (v.input_tokens ?? 0) + (v.output_tokens ?? 0) + (v.cache_creation_tokens ?? 0);
      }
    }
    const harnessTotal = Object.values(harnessTotals).reduce((s, v) => s + v, 0);
    const topHarness = Object.entries(harnessTotals).sort((a, b) => b[1] - a[1])[0];
    const topHarnessShare = topHarness && harnessTotal > 0 ? Math.round((topHarness[1] / harnessTotal) * 100) : 0;
    const topHarnessName = topHarness ? topHarness[0].charAt(0).toUpperCase() + topHarness[0].slice(1) : '';

    const kpis: Array<{ label: string; value: string; info: string; delta?: string; up?: boolean; sub?: string; accent?: boolean }> = [
      { label: 'Total Tokens', value: fmtTokens(totalTokens), info: 'Input + output + cache-creation tokens across all sessions and machines, all time. Matches Claude Code /stats. Cache reads excluded.', delta: dTokens.text, up: dTokens.up },
      { label: 'Sessions', value: totalSessions.toLocaleString(), info: 'Total AI coding sessions across all machines, all time.', delta: dSessions.text, up: dSessions.up },
      { label: 'Active Time', value: fmtMinutes(totalMinutes), info: 'Sum of all session durations across all machines, all time.', delta: dMinutes.text, up: dMinutes.up },
      { label: 'Current Streak', value: currentStreak > 0 ? `${currentStreak}d` : '—', info: 'Consecutive days with at least one session, ending today.', sub: longestStreak > 0 ? `longest ${longestStreak}d` : undefined, accent: true },
      { label: 'Top Harness', value: topHarnessShare > 0 ? `${topHarnessShare}%` : '—', info: 'Share of all-time tokens (input + output + cache-creation) on your most-used harness, across all machines.', sub: topHarnessName || undefined },
      { label: 'Tool Uses', value: fmtTokens(totalToolUses), info: 'Total tool invocations (file edits, searches, commands, etc.) all time.', sub: 'all time' },
    ];

    clearEl(kpiRowEl);
    for (const k of kpis) {
      const card = document.createElement('div');
      card.className = 'kpi';
      const header = document.createElement('div');
      header.className = 'kpi-header';
      const label = document.createElement('span');
      label.className = 'kpi-label';
      label.textContent = k.label;
      const infoBtn = document.createElement('span');
      infoBtn.className = 'info-icon';
      infoBtn.textContent = 'i';
      infoBtn.setAttribute('role', 'img');
      infoBtn.setAttribute('aria-label', k.info);
      const tooltip = document.createElement('span');
      tooltip.className = 'info-tooltip';
      tooltip.textContent = k.info;
      infoBtn.appendChild(tooltip);
      header.appendChild(label);
      header.appendChild(infoBtn);
      const value = document.createElement('span');
      value.className = 'kpi-value' + (k.accent ? ' accent' : '');
      value.textContent = k.value;
      card.appendChild(header);
      card.appendChild(value);
      if (k.delta && k.delta !== '—') {
        const delta = document.createElement('span');
        delta.className = 'kpi-delta' + (k.up ? '' : ' down');
        delta.textContent = k.delta + ' vs 30d';
        card.appendChild(delta);
      } else if (k.sub) {
        const sub = document.createElement('span');
        sub.className = 'kpi-sub';
        sub.textContent = k.sub;
        card.appendChild(sub);
      }
      kpiRowEl.appendChild(card);
    }
  }

  // ── Heatmap (shared painter) ───────────────────────────────────────
  function rangeBounds(range: 'L12M' | string): { startDate: Date; predicate: (d: string) => boolean } {
    const now = new Date();
    if (range === 'L12M') {
      const startDate = new Date(Date.UTC(now.getFullYear(), now.getMonth() - 11, 1));
      const startKey = dateStr(startDate);
      return { startDate, predicate: (d) => d >= startKey };
    }
    const yearNum = parseInt(range, 10);
    return { startDate: new Date(Date.UTC(yearNum, 0, 1)), predicate: (d) => d.startsWith(range) };
  }

  async function paintHeatmap(
    selector: string,
    startDate: Date,
    calData: Array<{ date: string; value: number }>,
    scale: { range: string[]; domain: number[] },
    tooltipText: (value: number | null, djs: { format: (f: string) => string }) => string,
  ): Promise<CalHeatmap> {
    // Size cells so the 52-week grid fills the card width (no dead space).
    const host = document.querySelector(selector) as HTMLElement | null;
    const w = host?.clientWidth ?? 800;
    const cell = Math.max(10, Math.min(15, Math.round(w / 53) - 3));
    const cal = new CalHeatmap();
    await cal.paint(
      {
        itemSelector: selector,
        data: { source: calData, x: (d: { date: string }) => +new Date(d.date), y: 'value', defaultValue: 0 },
        date: { start: startDate },
        range: 12,
        domain: { type: 'month', label: { text: 'MMM', textAlign: 'start', position: 'bottom' }, gutter: 4 },
        subDomain: { type: 'ghDay', radius: 2, width: cell, height: cell, gutter: 3 },
        scale: { color: { type: 'threshold', range: scale.range, domain: scale.domain } },
      },
      [[Tooltip, { text: (_ts: number, value: number | null, djs: { format: (f: string) => string }) => tooltipText(value, djs) }]]
    );
    return cal;
  }

  function scrollToEnd(id: string): void {
    const el = document.getElementById(id);
    if (!el) return;
    requestAnimationFrame(() => requestAnimationFrame(() => { el.scrollLeft = el.scrollWidth; }));
  }

  // Pull the Less/More legend in so its right edge lines up with the heatmap's.
  function alignHeatmapLegend(): void {
    const svg = document.querySelector('#cal-heatmap svg') as SVGElement | null;
    const row = document.querySelector('.stat-row') as HTMLElement | null;
    if (!svg || !row) return;
    row.style.paddingRight = '0px';
    const pad = Math.max(0, Math.round(row.getBoundingClientRect().right - svg.getBoundingClientRect().right));
    row.style.paddingRight = `${pad}px`;
  }

  async function renderHeatmap(range: 'L12M' | string, metric: string): Promise<void> {
    if (!vibestatsData) return;
    if (calInstance) { calInstance.destroy(); calInstance = null; }
    const { startDate, predicate } = rangeBounds(range);
    const calData = Object.entries(vibestatsData.days)
      .filter(([date]) => predicate(date))
      .map(([date, v]) => ({ date, value: metricValue(v, metric) }));
    const scale = colorScale(metric, calData.map(d => d.value));

    // Headline number + caption + legend, all in the metric's colour.
    const total = calData.reduce((s, d) => s + d.value, 0);
    heatNumberEl.textContent = metricNumber(metric, total);
    heatNumberEl.style.color = STEP4[metric];
    heatCaptionEl.textContent = METRIC_CAPTION[metric] ?? '';
    heatLegendEl.replaceChildren();
    for (const c of scale.range) {
      const sw = document.createElement('span');
      sw.className = 'swatch';
      sw.style.background = c;
      heatLegendEl.appendChild(sw);
    }
    for (const t of heatmapTabsEl.querySelectorAll<HTMLElement>('.pill')) {
      const active = t.dataset.metric === metric;
      t.classList.toggle('active', active);
      t.style.color = active ? STEP4[metric] : '';
      t.style.background = active ? `color-mix(in srgb, ${STEP4[metric]} 12%, transparent)` : '';
    }

    calInstance = await paintHeatmap('#cal-heatmap', startDate, calData, scale, (value, djs) => {
      const dateKey = djs.format('YYYY-MM-DD');
      const day = vibestatsData?.days[dateKey];
      if (!day || value === null || value === 0) return `No activity on ${djs.format('MMM D, YYYY')}`;
      const totalTok = tokensTotal(day);
      const topModel = day.models ? Object.entries(day.models).sort((a, b) => b[1] - a[1])[0]?.[0] : null;
      const mStr = topModel ? `, ${topModel.replace(/^claude-/, '')}` : '';
      const tStr = totalTok > 0 ? `, ${fmtTokens(totalTok)} tokens` : '';
      return `${djs.format('MMM D, YYYY')}: ${day.sessions} session${day.sessions === 1 ? '' : 's'}, ~${day.active_minutes} min${tStr}${mStr}`;
    });
    scrollToEnd('cal-heatmap');
    requestAnimationFrame(() => requestAnimationFrame(alignHeatmapLegend));
  }

  // ── GitHub contributions heatmap (its own card + range) ────────────
  async function renderGithub(range: 'L12M' | string): Promise<void> {
    if (!vibestatsData?.github_contributions) return;
    if (ghInstance) { ghInstance.destroy(); ghInstance = null; }
    const { startDate, predicate } = rangeBounds(range);
    const calData = Object.entries(vibestatsData.github_contributions)
      .filter(([date]) => predicate(date))
      .map(([date, v]) => ({ date, value: v.total ?? 0 }));
    const scale = colorScale('github', calData.map(d => d.value));
    const total = calData.reduce((s, d) => s + d.value, 0);
    ghCountEl.textContent = `${total.toLocaleString()} contribution${total === 1 ? '' : 's'}`;

    ghInstance = await paintHeatmap('#gh-heatmap', startDate, calData, scale, (value, djs) => {
      const dateKey = djs.format('YYYY-MM-DD');
      const gh = vibestatsData?.github_contributions?.[dateKey];
      if (!gh || value === null || value === 0) return `No contributions on ${djs.format('MMM D, YYYY')}`;
      const priv = Math.max(0, gh.total - gh.commits - gh.prs - gh.issues - gh.reviews);
      return `${djs.format('MMM D, YYYY')}: ${gh.total} contribution${gh.total === 1 ? '' : 's'} `
        + `(${gh.commits} commits, ${gh.prs} PRs, ${gh.issues} issues, ${gh.reviews} reviews, ${priv} private)`;
    });
    scrollToEnd('gh-heatmap');
  }

  // ── Weekly token consumption (12 weeks, stacked) ───────────────────
  function renderTokenChart(data: VibestatsData): void {
    const now = new Date();
    const weeks: Array<{ input: number; output: number; cacheCreate: number }> = [];
    for (let w = 11; w >= 0; w--) {
      const weekEnd = new Date(now);
      weekEnd.setDate(weekEnd.getDate() - w * 7);
      const weekStart = new Date(weekEnd);
      weekStart.setDate(weekStart.getDate() - 6);
      const entries = daysInRange(data, weekStart, weekEnd);
      weeks.push({
        input: sumField(entries, e => e.input_tokens ?? 0),
        output: sumField(entries, e => e.output_tokens ?? 0),
        cacheCreate: sumField(entries, e => e.cache_creation_tokens ?? 0),
      });
    }
    const maxVal = Math.max(1, ...weeks.map(w => w.input + w.output + w.cacheCreate));
    clearEl(tokenChartEl);
    for (const wk of weeks) {
      const total = wk.output + wk.input + wk.cacheCreate;
      const col = document.createElement('div');
      col.className = 'tbar';
      const fill = document.createElement('div');
      fill.className = 'tbar-fill';
      fill.style.height = `${(total / maxVal) * 100}%`;
      if (total === 0) { fill.classList.add('empty'); fill.style.height = '2%'; }
      else {
        // Bottom → top: output (deep), input (mid), cache create (light).
        for (const [value, color] of [
          [wk.output, '#ea580c'],
          [wk.input, '#fb923c'],
          [wk.cacheCreate, '#fed7aa'],
        ] as Array<[number, string]>) {
          const seg = document.createElement('div');
          seg.className = 'tseg';
          seg.style.flexBasis = `${(value / total) * 100}%`;
          seg.style.background = color;
          fill.appendChild(seg);
        }
      }
      col.title = `${fmtTokens(wk.output)} output · ${fmtTokens(wk.input)} input · ${fmtTokens(wk.cacheCreate)} cache (${fmtTokens(total)} total)`;
      col.appendChild(fill);
      tokenChartEl.appendChild(col);
    }
  }

  // ── Model donut ────────────────────────────────────────────────────
  function renderModelChart(data: VibestatsData): void {
    const harnessOf = (model: string): string | null => {
      if (/^claude-/.test(model)) return 'claude';
      if (/^(gpt-|o\d|codex)/i.test(model)) return 'codex';
      return null;
    };
    const modelTotals: Record<string, number> = {};
    for (const d of Object.values(data.days)) {
      const harnessOut: Record<string, number> = {};
      for (const [model, out] of Object.entries(d.models ?? {})) {
        const h = harnessOf(model);
        if (!h) continue;
        harnessOut[h] = (harnessOut[h] ?? 0) + out;
      }
      for (const [model, out] of Object.entries(d.models ?? {})) {
        const h = harnessOf(model);
        const harnessIn = h ? (d.harnesses?.[h]?.input_tokens ?? 0) : 0;
        const harnessCacheCreate = h ? (d.harnesses?.[h]?.cache_creation_tokens ?? 0) : 0;
        const totalOutForHarness = h ? harnessOut[h] : 0;
        const weight = totalOutForHarness > 0 ? out / totalOutForHarness : 0;
        modelTotals[model] = (modelTotals[model] ?? 0) + out + weight * harnessIn + weight * harnessCacheCreate;
      }
    }
    const sorted = Object.entries(modelTotals).sort((a, b) => b[1] - a[1]);
    const total = sorted.reduce((s, [, v]) => s + v, 0);
    const modelCount = sorted.length;
    clearEl(modelChartEl);
    if (total === 0) {
      const msg = document.createElement('p');
      msg.style.cssText = 'color:var(--muted);font-size:0.85rem';
      msg.textContent = 'No model data available';
      modelChartEl.appendChild(msg);
      return;
    }
    // Single-hue accent ramp (green is reserved for GitHub).
    const colors = [
      'var(--accent)',
      'color-mix(in srgb, var(--accent) 70%, #fff)',
      'color-mix(in srgb, var(--accent) 46%, #fff)',
      'color-mix(in srgb, var(--accent) 26%, #fff)',
      'var(--border)',
    ];
    const formatModelLabel = (m: string): string =>
      m === 'Other' ? m : m.replace(/^claude-/, '').replace(/-(\d)/, ' $1');

    const TOP_N = 3;
    const top: Array<[string, number]> = sorted.slice(0, TOP_N);
    const otherTotal = sorted.slice(TOP_N).reduce((s, [, v]) => s + v, 0);
    if (otherTotal > 0) top.push(['Other', otherTotal]);

    const slices: Array<{ name: string; pct: number; color: string; startPct: number; endPct: number }> = [];
    let cumPct = 0;
    for (let i = 0; i < top.length; i++) {
      const pct = (top[i][1] / total) * 100;
      slices.push({ name: top[i][0], pct: Math.round(pct), color: colors[i] ?? colors[colors.length - 1], startPct: cumPct / 100, endPct: (cumPct + pct) / 100 });
      cumPct += pct;
    }

    const SIZE = 170, CX = 85, CY = 85, R_OUTER = 80, R_INNER = 50;
    const SVG_NS = 'http://www.w3.org/2000/svg';
    const arcPath = (startPct: number, endPct: number): string => {
      const sweep = Math.min(endPct - startPct, 0.9999);
      const a0 = startPct * 2 * Math.PI - Math.PI / 2;
      const a1 = (startPct + sweep) * 2 * Math.PI - Math.PI / 2;
      const xO0 = CX + R_OUTER * Math.cos(a0), yO0 = CY + R_OUTER * Math.sin(a0);
      const xO1 = CX + R_OUTER * Math.cos(a1), yO1 = CY + R_OUTER * Math.sin(a1);
      const xI0 = CX + R_INNER * Math.cos(a0), yI0 = CY + R_INNER * Math.sin(a0);
      const xI1 = CX + R_INNER * Math.cos(a1), yI1 = CY + R_INNER * Math.sin(a1);
      const large = sweep > 0.5 ? 1 : 0;
      return `M${xO0} ${yO0} A${R_OUTER} ${R_OUTER} 0 ${large} 1 ${xO1} ${yO1} L${xI1} ${yI1} A${R_INNER} ${R_INNER} 0 ${large} 0 ${xI0} ${yI0} Z`;
    };
    const donutWrap = document.createElement('div');
    donutWrap.className = 'donut-box';
    const svg = document.createElementNS(SVG_NS, 'svg');
    svg.setAttribute('class', 'donut');
    svg.setAttribute('viewBox', `0 0 ${SIZE} ${SIZE}`);
    svg.setAttribute('role', 'img');
    svg.setAttribute('aria-label', 'Model usage breakdown');
    for (const s of slices) {
      const path = document.createElementNS(SVG_NS, 'path');
      path.setAttribute('d', arcPath(s.startPct, s.endPct));
      path.setAttribute('fill', s.color);
      const t = document.createElementNS(SVG_NS, 'title');
      t.textContent = `${formatModelLabel(s.name)}: ${s.pct}%`;
      path.appendChild(t);
      svg.appendChild(path);
    }
    const center = document.createElement('div');
    center.className = 'donut-center';
    center.innerHTML = `<span class="donut-center-num">${modelCount}</span><span class="donut-center-lbl">models</span>`;
    donutWrap.appendChild(svg);
    donutWrap.appendChild(center);

    const legend = document.createElement('div');
    legend.className = 'donut-legend';
    for (const s of slices.slice(0, 3)) {
      const item = document.createElement('div');
      item.className = 'legend-item';
      item.title = `${formatModelLabel(s.name)}: ${s.pct}%`;
      const dot = document.createElement('span');
      dot.className = 'legend-dot';
      dot.style.background = s.color;
      const label = document.createElement('span');
      label.textContent = `${formatModelLabel(s.name)} · ${s.pct}%`;
      item.appendChild(dot);
      item.appendChild(label);
      legend.appendChild(item);
    }
    modelChartEl.appendChild(donutWrap);
    modelChartEl.appendChild(legend);
  }

  // ── Efficiency (Tokens/min · Cache hit rate · Avg session) ─────────
  function renderEfficiency(data: VibestatsData): void {
    const allDays = Object.values(data.days);
    const totalTokens = sumField(allDays, tokensTotal);
    const totalMinutes = sumField(allDays, e => e.active_minutes);
    const totalSessions = sumField(allDays, e => e.sessions);
    const totalCacheRead = sumField(allDays, e => e.cache_read_tokens ?? 0);
    const totalCacheCreation = sumField(allDays, e => e.cache_creation_tokens ?? 0);
    const totalInput = sumField(allDays, e => e.input_tokens ?? 0);

    const tokPerMin = totalMinutes > 0 ? Math.round(totalTokens / totalMinutes) : 0;
    const cacheDenom = totalInput + totalCacheCreation;
    const cacheHitPct = cacheDenom > 0 ? Math.round((totalCacheRead / cacheDenom) * 100) : 0;
    const avgSession = totalSessions > 0 ? (totalMinutes / totalSessions) : 0;

    const now = new Date();
    const wTokPerMin: number[] = [], wCacheHit: number[] = [], wAvgSession: number[] = [];
    for (let w = 11; w >= 0; w--) {
      const weekEnd = new Date(now);
      weekEnd.setDate(weekEnd.getDate() - w * 7);
      const weekStart = new Date(weekEnd);
      weekStart.setDate(weekStart.getDate() - 6);
      const entries = daysInRange(data, weekStart, weekEnd);
      const wTok = sumField(entries, tokensTotal);
      const wMin = sumField(entries, e => e.active_minutes);
      const wSes = sumField(entries, e => e.sessions);
      const wCacheRead = sumField(entries, e => e.cache_read_tokens ?? 0);
      const wInput = sumField(entries, e => e.input_tokens ?? 0);
      const wCacheCreate = sumField(entries, e => e.cache_creation_tokens ?? 0);
      wTokPerMin.push(wMin > 0 ? wTok / wMin : 0);
      const wd = wInput + wCacheCreate;
      wCacheHit.push(wd > 0 ? (wCacheRead / wd) * 100 : 0);
      wAvgSession.push(wSes > 0 ? wMin / wSes : 0);
    }

    const rows = [
      { label: 'Tokens / min', value: fmtTokens(tokPerMin), data: wTokPerMin },
      { label: 'Cache hit rate', value: `${cacheHitPct}%`, data: wCacheHit },
      { label: 'Avg session', value: `${avgSession.toFixed(1)}m`, data: wAvgSession },
    ];
    clearEl(efficiencyEl);
    for (const m of rows) {
      const row = document.createElement('div');
      row.className = 'eff-row';
      const meta = document.createElement('div');
      meta.className = 'eff-meta';
      meta.innerHTML = `<span class="eff-label">${m.label}</span><span class="eff-value">${m.value}</span>`;
      const spark = document.createElement('div');
      spark.className = 'eff-spark';
      const max = Math.max(1, ...m.data);
      for (let i = 0; i < m.data.length; i++) {
        const bar = document.createElement('span');
        bar.style.height = `${Math.max((m.data[i] / max) * 100, 4)}%`;
        bar.style.opacity = String(0.4 + (i / m.data.length) * 0.6);
        spark.appendChild(bar);
      }
      row.appendChild(meta);
      row.appendChild(spark);
      efficiencyEl.appendChild(row);
    }
  }

  // ── Range selector ─────────────────────────────────────────────────
  function fillRangeSelect(sel: HTMLSelectElement, years: string[], selected: 'L12M' | string): void {
    clearEl(sel);
    for (const r of ['L12M', ...years] as Array<'L12M' | string>) {
      const opt = document.createElement('option');
      opt.value = r;
      opt.textContent = r === 'L12M' ? 'Last 12 months' : r;
      if (r === selected) opt.selected = true;
      sel.appendChild(opt);
    }
  }

  // ── Events ─────────────────────────────────────────────────────────
  heatmapTabsEl.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.pill') as HTMLButtonElement | null;
    if (!btn || !vibestatsData) return;
    const metric = btn.dataset.metric!;
    if (metric === currentMetric) return;
    currentMetric = metric;
    renderHeatmap(currentRange, metric);
  });
  yearSelectEl.addEventListener('change', () => { currentRange = yearSelectEl.value; renderHeatmap(currentRange, currentMetric); });
  ghYearSelectEl.addEventListener('change', () => { ghRange = ghYearSelectEl.value; renderGithub(ghRange); });

  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    requestAnimationFrame(() => {
      if (!vibestatsData) return;
      renderHeatmap(currentRange, currentMetric);
      if (!githubCardEl.hidden) renderGithub(ghRange);
    });
  });

  let resizeTimer = 0;
  window.addEventListener('resize', () => {
    window.clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(() => {
      if (!vibestatsData) return;
      renderHeatmap(currentRange, currentMetric);
      if (!githubCardEl.hidden) renderGithub(ghRange);
    }, 150);
  });

  shareBtnEl.addEventListener('click', async () => {
    try { await navigator.clipboard.writeText(window.location.href); shareBtnEl.textContent = 'Copied ✓'; }
    catch { shareBtnEl.textContent = 'Failed'; }
    window.setTimeout(() => { shareBtnEl.textContent = 'Share'; }, 1600);
  });
  // ── Main init ──────────────────────────────────────────────────────
  async function init(): Promise<void> {
    if (!username) { showError(`No vibestats data found for @${rawSegment || 'unknown'}`); return; }
    let data: VibestatsData;
    try {
      const earlyPromise = window.__vibestatsData as Promise<VibestatsData | null> | undefined;
      if (earlyPromise) {
        const result = await earlyPromise;
        if (!result) { showError(`No vibestats data found for @${username}`); return; }
        data = result;
      } else {
        const url = `https://raw.githubusercontent.com/${username}/${username}/main/vibestats/data.json?v=${Date.now()}`;
        const resp = await fetch(url, { cache: 'no-store' });
        if (!resp.ok) { showError(`No vibestats data found for @${username}`); return; }
        data = (await resp.json()) as VibestatsData;
      }
    } catch { showError(`No vibestats data found for @${username}`); return; }

    if (!data || typeof data.days !== 'object' || data.days === null) {
      showError(`No vibestats data found for @${username}`); return;
    }
    vibestatsData = data;

    const years = [...new Set([
      ...Object.keys(data.days),
      ...Object.keys(data.github_contributions ?? {}),
    ].map(d => d.slice(0, 4)))].sort((a, b) => b.localeCompare(a));
    if (years.length === 0) { showError(`No vibestats data found for @${username}`); return; }

    // Profile meta: "Tracking since <Mon YYYY> · Claude Code + Codex"
    const dayKeys = Object.keys(data.days).sort();
    const since = dayKeys.length ? new Date(dayKeys[0] + 'T00:00:00') : null;
    const sinceStr = since ? since.toLocaleDateString('en', { month: 'short', year: 'numeric' }) : '';
    subtitleEl.textContent = sinceStr
      ? `Tracking since ${sinceStr} · Claude Code + Codex`
      : 'AI Coding Analytics';

    // Machines pill (only if the aggregate exposes a machine list).
    const machineCount = Array.isArray(data.machines) ? data.machines.length : 0;
    if (machineCount > 0) {
      machinesPillEl.textContent = `${machineCount} machine${machineCount === 1 ? '' : 's'}`;
      machinesPillEl.hidden = false;
    }

    currentRange = 'L12M';
    ghRange = 'L12M';

    loadingEl.hidden = true;
    contentEl.hidden = false;

    renderKPIs(data);
    fillRangeSelect(yearSelectEl, years, currentRange);
    await renderHeatmap(currentRange, currentMetric);
    renderTokenChart(data);
    renderModelChart(data);
    renderEfficiency(data);

    if (data.github_contributions && Object.keys(data.github_contributions).length > 0) {
      githubCardEl.hidden = false;
      fillRangeSelect(ghYearSelectEl, years, ghRange);
      await renderGithub(ghRange);
    }
  }

  init();
</script>

