---
import Base from '../layouts/Base.astro';
---
<Base title="vibestats dashboard">
  <!-- Early fetch: start data download in <head>, before the 316KB module loads -->
  <script is:inline slot="head">
    (function() {
      var RE = /^[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,38})$/;
      var seg = window.location.pathname.split('/').filter(Boolean)[0] || '';
      var user = RE.test(seg) ? seg : '';
      if (user) {
        window.__vibestatsData = fetch(
          'https://raw.githubusercontent.com/' + user + '/' + user + '/main/vibestats/data.json'
        ).then(function(r) { return r.ok ? r.json() : null; })
         .catch(function() { return null; });
      }
    })();
  </script>
  <main class="dashboard">
    <header class="dash-header">
      <h1 id="dash-title">vibestats dashboard</h1>
      <p id="dash-subtitle" class="subtitle"></p>
    </header>

    <div id="loading-state" class="state-msg">
      <div class="spinner" aria-hidden="true"></div>
      Loading dashboard&hellip;
    </div>
    <div id="error-state" class="state-msg error" hidden></div>

    <section id="dashboard-content" hidden>
      <div id="stats-summary" class="stats-summary" hidden></div>
      <div id="year-toggle" class="year-toggle" aria-label="Select year"></div>
      <div class="heatmap-wrapper">
        <div class="day-labels" aria-hidden="true">
          <span></span>
          <span>Mon</span>
          <span></span>
          <span>Wed</span>
          <span></span>
          <span>Fri</span>
          <span></span>
        </div>
        <div id="cal-heatmap"></div>
      </div>
    </section>
  </main>
</Base>

<script>
  import CalHeatmap from 'cal-heatmap';
  import Tooltip from 'cal-heatmap/plugins/Tooltip';
  import 'cal-heatmap/cal-heatmap.css';

  // ── Types ──────────────────────────────────────────────────────────────────
  interface DayEntry {
    sessions: number;
    active_minutes: number;
    input_tokens?: number;
    output_tokens?: number;
    cache_read_tokens?: number;
    cache_creation_tokens?: number;
    models?: Record<string, number>;
    longest_session_minutes?: number;
    message_count?: number;
    tool_uses?: number;
  }

  interface VibestatsData {
    generated_at: string;
    username: string;
    days: Record<string, DayEntry>;
  }

  // ── DOM refs ───────────────────────────────────────────────────────────────
  const loadingEl = document.getElementById('loading-state') as HTMLElement;
  const errorEl = document.getElementById('error-state') as HTMLElement;
  const contentEl = document.getElementById('dashboard-content') as HTMLElement;
  const titleEl = document.getElementById('dash-title') as HTMLElement;
  const subtitleEl = document.getElementById('dash-subtitle') as HTMLElement;
  const yearToggleEl = document.getElementById('year-toggle') as HTMLElement;
  const statsSummaryEl = document.getElementById('stats-summary') as HTMLElement;

  // ── Username discovery ─────────────────────────────────────────────────────
  const GH_USERNAME_RE = /^[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,38})$/;
  const rawSegment = window.location.pathname.split('/').filter(Boolean)[0] ?? '';
  const username = GH_USERNAME_RE.test(rawSegment) ? rawSegment : '';

  if (username) {
    document.title = `vibestats — @${username} dashboard`;
    titleEl.textContent = `@${username}`;
    subtitleEl.textContent = 'Claude Code activity heatmap';
  }

  // ── State ──────────────────────────────────────────────────────────────────
  let calInstance: CalHeatmap | null = null;
  let vibestatsData: VibestatsData | null = null;

  // ── Error helper ───────────────────────────────────────────────────────────
  function showError(msg: string): void {
    loadingEl.hidden = true;
    errorEl.textContent = msg;
    errorEl.hidden = false;
  }

  // ── Format helpers ─────────────────────────────────────────────────────────
  function fmtTokens(n: number): string {
    if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M`;
    if (n >= 1_000) return `${(n / 1_000).toFixed(1)}K`;
    return String(n);
  }

  // ── Compute and render all-time stats summary ───────────────────────────────
  function renderStatsSummary(data: VibestatsData): void {
    const allDays = Object.values(data.days);
    if (allDays.length === 0) { statsSummaryEl.hidden = true; return; }

    // Totals
    const totalSessions = allDays.reduce((s, d) => s + d.sessions, 0);
    const totalMinutes = allDays.reduce((s, d) => s + d.active_minutes, 0);
    const totalInput = allDays.reduce((s, d) => s + (d.input_tokens ?? 0), 0);
    const totalOutput = allDays.reduce((s, d) => s + (d.output_tokens ?? 0), 0);
    const totalTokens = totalInput + totalOutput;
    const longestSession = allDays.reduce((m, d) => Math.max(m, d.longest_session_minutes ?? 0), 0);

    // Favorite model (highest output_tokens across all days)
    const modelTotals: Record<string, number> = {};
    for (const d of allDays) {
      for (const [model, count] of Object.entries(d.models ?? {})) {
        modelTotals[model] = (modelTotals[model] ?? 0) + count;
      }
    }
    const favoriteModel = Object.keys(modelTotals).sort((a, b) => modelTotals[b] - modelTotals[a])[0] ?? null;

    // Streaks (consecutive active days)
    const activeDates = new Set(Object.keys(data.days));
    const today = new Date().toISOString().slice(0, 10);
    let longestStreak = 0;
    let streak = 0;
    const sortedDates = [...activeDates].sort();
    for (let i = 0; i < sortedDates.length; i++) {
      if (i === 0) { streak = 1; }
      else {
        const prev = new Date(sortedDates[i - 1]);
        const curr = new Date(sortedDates[i]);
        const diff = (curr.getTime() - prev.getTime()) / 86_400_000;
        streak = diff === 1 ? streak + 1 : 1;
      }
      longestStreak = Math.max(longestStreak, streak);
    }
    // Current streak: consecutive days ending at today or yesterday
    let currentStreak = 0;
    const checkDate = new Date(today);
    while (activeDates.has(checkDate.toISOString().slice(0, 10))) {
      currentStreak++;
      checkDate.setDate(checkDate.getDate() - 1);
    }

    const modelLabel = favoriteModel
      ? favoriteModel.replace(/^claude-/, '').replace(/-(\d)/, ' $1')
      : null;

    const stats: Array<{ label: string; value: string }> = [
      { label: 'Total tokens', value: totalTokens > 0 ? fmtTokens(totalTokens) : '—' },
      { label: 'Sessions', value: totalSessions.toLocaleString() },
      { label: 'Active time', value: totalMinutes >= 60 ? `${Math.round(totalMinutes / 60)}h` : `${totalMinutes}m` },
      { label: 'Longest session', value: longestSession > 0 ? `${longestSession}m` : '—' },
      { label: 'Current streak', value: currentStreak > 0 ? `${currentStreak}d` : '—' },
      { label: 'Longest streak', value: longestStreak > 0 ? `${longestStreak}d` : '—' },
      ...(modelLabel ? [{ label: 'Top model', value: modelLabel }] : []),
    ];

    // Build DOM safely — no innerHTML
    while (statsSummaryEl.firstChild) statsSummaryEl.removeChild(statsSummaryEl.firstChild);
    for (const s of stats) {
      const card = document.createElement('div');
      card.className = 'stat-card';
      const valEl = document.createElement('span');
      valEl.className = 'stat-value';
      valEl.textContent = s.value;
      const labelEl = document.createElement('span');
      labelEl.className = 'stat-label';
      labelEl.textContent = s.label;
      card.appendChild(valEl);
      card.appendChild(labelEl);
      statsSummaryEl.appendChild(card);
    }
    statsSummaryEl.hidden = false;
  }

  // ── Render GitHub-style heatmap for a given year ────────────────────────────
  async function renderHeatmap(selectedYear: string): Promise<void> {
    if (!vibestatsData) return;

    if (calInstance) {
      calInstance.destroy();
      calInstance = null;
    }

    const calData = Object.entries(vibestatsData.days)
      .filter(([date]) => date.startsWith(selectedYear))
      .map(([date, v]) => ({ date, value: v.sessions }));


    const now = new Date();
    const yearNum = parseInt(selectedYear, 10);
    const isCurrentYear = yearNum === now.getFullYear();

    // Current year: rolling view from ~1 year ago. Past years: Jan 1 – Dec 31.
    const startDate = isCurrentYear
      ? new Date(yearNum - 1, now.getMonth(), now.getDate())
      : new Date(`${selectedYear}-01-01`);
    const range = isCurrentYear ? 13 : 12;

    const cal = new CalHeatmap();
    await cal.paint(
      {
        itemSelector: '#cal-heatmap',
        data: {
          source: calData,
          x: (datum) => +new Date(datum['date'] as string),
          y: 'value',
          defaultValue: 0,
        },
        date: { start: startDate },
        range,
        domain: {
          type: 'month',
          label: { text: 'MMM', textAlign: 'start', position: 'top' },
          gutter: 4,
        },
        subDomain: {
          type: 'ghDay',
          radius: 2,
          width: 11,
          height: 11,
          gutter: 2,
        },
        scale: {
          color: {
            type: 'threshold',
            range: ['#ebedf0', '#fef3e8', '#fed7aa', '#fb923c', '#f97316'],
            domain: [1, 10, 50, 100],
          },
        },
      },
      [
        [
          Tooltip,
          {
            text: (_timestamp: number, value: number | null, dayjsDate: { format: (fmt: string) => string }) => {
              const dateKey = dayjsDate.format('YYYY-MM-DD');
              const dayData = vibestatsData?.days[dateKey];
              if (!dayData || value === null || value === 0) {
                return `No activity on ${dayjsDate.format('MMM D, YYYY')}`;
              }
              const totalTokens = (dayData.input_tokens ?? 0) + (dayData.output_tokens ?? 0);
              const topModel = dayData.models
                ? Object.entries(dayData.models).sort((a, b) => b[1] - a[1])[0]?.[0]
                : null;
              const modelStr = topModel ? `, ${topModel.replace(/^claude-/, '')}` : '';
              const tokStr = totalTokens > 0 ? `, ${fmtTokens(totalTokens)} tokens` : '';
              return `${dayjsDate.format('MMM D, YYYY')}: ${dayData.sessions} session${dayData.sessions === 1 ? '' : 's'}, ~${dayData.active_minutes} min${tokStr}${modelStr}`;
            },
          },
        ],
      ]
    );

    calInstance = cal;
  }

  // ── Year toggle ────────────────────────────────────────────────────────────
  function renderYearToggle(years: string[], selectedYear: string): void {
    while (yearToggleEl.firstChild) {
      yearToggleEl.removeChild(yearToggleEl.firstChild);
    }

    for (const year of years) {
      const btn = document.createElement('button');
      btn.textContent = year;
      btn.className = 'year-btn' + (year === selectedYear ? ' active' : '');
      btn.setAttribute('aria-pressed', String(year === selectedYear));
      btn.addEventListener('click', async () => {
        for (const b of yearToggleEl.querySelectorAll('.year-btn')) {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
        }
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');
        try {
          await renderHeatmap(year);
        } catch (err) {
          showError(`Failed to render dashboard for @${username}: ${err instanceof Error ? err.message : String(err)}`);
        }
      });
      yearToggleEl.appendChild(btn);
    }
  }

  // ── Main: fetch data.json and boot dashboard ───────────────────────────────
  async function init(): Promise<void> {
    if (!username) {
      const display = rawSegment || 'unknown';
      showError(`No vibestats data found for @${display}`);
      return;
    }

    // Reuse the early fetch started in <head>, or fall back to a fresh fetch.
    let data: VibestatsData;
    try {
      const earlyPromise = (window as Record<string, unknown>).__vibestatsData as
        | Promise<VibestatsData | null>
        | undefined;
      if (earlyPromise) {
        const result = await earlyPromise;
        if (!result) {
          showError(`No vibestats data found for @${username}`);
          return;
        }
        data = result;
      } else {
        const url = `https://raw.githubusercontent.com/${username}/${username}/main/vibestats/data.json`;
        const resp = await fetch(url);
        if (!resp.ok) {
          showError(`No vibestats data found for @${username}`);
          return;
        }
        data = (await resp.json()) as VibestatsData;
      }
    } catch {
      showError(`No vibestats data found for @${username}`);
      return;
    }

    if (!data || typeof data.days !== 'object' || data.days === null) {
      showError(`No vibestats data found for @${username}`);
      return;
    }

    vibestatsData = data;

    const years = [
      ...new Set(Object.keys(data.days).map(d => d.slice(0, 4))),
    ].sort((a, b) => b.localeCompare(a));

    if (years.length === 0) {
      showError(`No vibestats data found for @${username}`);
      return;
    }

    const currentYear = String(new Date().getFullYear());
    const defaultYear = years.includes(currentYear) ? currentYear : years[0];

    // Show content section and render
    try {
      loadingEl.hidden = true;
      contentEl.hidden = false;

      renderStatsSummary(data);
      renderYearToggle(years, defaultYear);
      await renderHeatmap(defaultYear);
    } catch (err) {
      showError(`Failed to render dashboard for @${username}: ${err instanceof Error ? err.message : String(err)}`);
    }
  }

  init();
</script>

<style>
  .dashboard {
    max-width: 960px;
    margin: 2rem auto;
    padding: 0 1rem;
  }

  .dash-header {
    margin-bottom: 1.5rem;
  }

  .dash-header h1 {
    font-size: 1.75rem;
    margin: 0 0 0.25rem;
  }

  .subtitle {
    color: #6b7280;
    margin: 0;
  }

  .state-msg {
    text-align: center;
    padding: 2rem;
    color: #6b7280;
  }

  .state-msg.error {
    color: #dc2626;
  }

  .spinner {
    width: 24px;
    height: 24px;
    margin: 0 auto 0.5rem;
    border: 3px solid #e5e7eb;
    border-top-color: #f97316;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .stats-summary {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 0.5rem 0.875rem;
    min-width: 80px;
  }

  .stat-value {
    font-size: 1.125rem;
    font-weight: 700;
    color: #111827;
    line-height: 1.3;
  }

  .stat-label {
    font-size: 0.7rem;
    color: #6b7280;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-top: 0.125rem;
  }

  .heatmap-wrapper {
    display: flex;
    align-items: flex-start;
    overflow-x: auto;
  }

  .day-labels {
    display: flex;
    flex-direction: column;
    padding-top: 22px;
    margin-right: 4px;
    flex-shrink: 0;
  }

  .day-labels span {
    height: 11px;
    margin-bottom: 2px;
    font-size: 9px;
    line-height: 11px;
    color: #9ca3af;
  }

  #cal-heatmap {
    overflow-x: auto;
  }
</style>

<!-- Unscoped: year-toggle buttons are created dynamically via JS -->
<style is:global>
  .year-toggle {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .year-btn {
    padding: 0.25rem 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 4px;
    background: #fff;
    cursor: pointer;
    font-size: 0.875rem;
    color: #374151;
  }

  .year-btn:hover {
    background: #f9fafb;
    border-color: #9ca3af;
  }

  .year-btn.active {
    background: #f97316;
    border-color: #f97316;
    color: #fff;
    font-weight: 600;
  }
</style>
